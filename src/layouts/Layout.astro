---
export interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
}

const { 
	title = 'AH3 Tools — Plugin 3ds Max chuyên nghiệp | HKD ArchiH3',
	description = 'Bộ công cụ AI và tự động hóa 3ds Max chuyên nghiệp. Phát triển bởi HKD Dịch vụ Kiến Trúc ArchiH3.',
	ogImage = 'https://archih3.com/logo.png'
} = Astro.props;
---

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title>{title}</title>
    <meta name="description" content={description}>
    <link rel="canonical" href="https://archih3.com">
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:image" content={ogImage}>
    <meta property="og:url" content="https://archih3.com">
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    
    <link rel="stylesheet" href="/assets/css/global.css?v=3">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <slot name="head" />
</head>
<body>
    <slot />
    <!-- LANGUAGE SWITCH JS -->
    <script is:inline src="/assets/js/lang.js"></script>
    <script is:inline src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script is:inline>
        document.addEventListener("DOMContentLoaded", function() {
            if (typeof AOS !== 'undefined') {
                AOS.init({
                    duration: 800,
                    once: true,
                    offset: 100
                });
            }

            // Auto-hide navbar on mobile
            (function() {
                var nav = document.querySelector('nav');
                if (!nav) return;
                var lastY = 0;
                var ticking = false;
                var THRESHOLD = 5;

                function onScroll() {
                    if (window.innerWidth > 768) {
                        nav.classList.remove('nav-hidden', 'nav-scrolled');
                        return;
                    }
                    var y = window.scrollY;
                    if (y > 60) {
                        nav.classList.add('nav-scrolled');
                    } else {
                        nav.classList.remove('nav-scrolled', 'nav-hidden');
                    }
                    if (Math.abs(y - lastY) < THRESHOLD) return;
                    if (y > lastY && y > 80) {
                        // Scrolling DOWN & past hero
                        nav.classList.add('nav-hidden');
                        // Close mobile menu if open
                        var links = nav.querySelector('.nav-links');
                        if (links) links.classList.remove('open');
                    } else {
                        // Scrolling UP
                        nav.classList.remove('nav-hidden');
                    }
                    lastY = y;
                }

                window.addEventListener('scroll', function() {
                    if (!ticking) {
                        requestAnimationFrame(function() {
                            onScroll();
                            ticking = false;
                        });
                        ticking = true;
                    }
                }, { passive: true });
            })();
        });
    </script>
</body>
</html>
