---
export interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
}

const {
	title = 'AH3 Tools — Plugin 3ds Max chuyên nghiệp | HKD ArchiH3',
	description = 'Bộ công cụ AI và tự động hóa 3ds Max chuyên nghiệp. Phát triển bởi HKD Dịch vụ Kiến Trúc ArchiH3.',
	ogImage = 'https://archih3.com/logo.png'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title>{title}</title>
    <meta name="description" content={description}>
    <link rel="canonical" href={canonicalURL}>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:image" content={ogImage}>
    <meta property="og:url" content={canonicalURL}>
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    
    <link rel="icon" href="/favicon.ico" sizes="32x32">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="stylesheet" href="/assets/css/global.css?v=4">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <slot name="head" />
</head>
<body>
    <slot />
    <!-- LANGUAGE SWITCH JS -->
    <script is:inline src="/assets/js/lang.js"></script>
    <script is:inline src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script is:inline>
        document.addEventListener("DOMContentLoaded", function() {
            if (typeof AOS !== 'undefined') {
                AOS.init({
                    duration: 800,
                    once: true,
                    offset: 100
                });
            } else {
                // CDN failed: make [data-aos] elements visible instead of leaving them hidden
                document.querySelectorAll('[data-aos]').forEach(function(el) {
                    el.style.opacity = '1';
                    el.style.transform = 'none';
                });
            }

            // Mobile FAB + navbar toggle
            (function() {
                var nav = document.querySelector('nav');
                var fab = document.getElementById('mobile-fab');
                if (!nav || !fab) return;
                var navLinks = nav.querySelector('.nav-links');
                var isOpen = false;

                fab.addEventListener('click', function() {
                    isOpen = !isOpen;
                    if (isOpen) {
                        nav.classList.add('nav-visible');
                        if (navLinks) navLinks.classList.add('open');
                        fab.classList.add('fab-open');
                    } else {
                        nav.classList.remove('nav-visible');
                        if (navLinks) navLinks.classList.remove('open');
                        fab.classList.remove('fab-open');
                    }
                });

                // Close when scrolling down
                var lastY = 0;
                window.addEventListener('scroll', function() {
                    if (window.innerWidth > 768) return;
                    var y = window.scrollY;
                    if (y > lastY && y > 50 && isOpen) {
                        isOpen = false;
                        nav.classList.remove('nav-visible');
                        if (navLinks) navLinks.classList.remove('open');
                        fab.classList.remove('fab-open');
                    }
                    lastY = y;
                }, { passive: true });
            })();
        });
    </script>
</body>
</html>
