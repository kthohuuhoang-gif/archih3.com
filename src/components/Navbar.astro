---
// Navbar.astro
---
<nav>
    <a href="/" class="logo"><img src="/logo.png" alt="AH3" style="height:24px; vertical-align:middle; margin-right:6px; opacity:0.85;">AH3<span> Portal</span></a>
    <button class="mobile-menu-btn" onclick="document.querySelector('.nav-links').classList.toggle('open')" style="display:none; background:none; border:1px solid var(--border); border-radius:6px; padding:6px 10px; color:var(--text); font-size:18px; cursor:pointer;">☰</button>
    <div class="nav-links">
        <div class="nav-dropdown-wrapper">
                <a href="#products" class="dropdown-trigger" data-vi="Sản phẩm ▾" data-en="Products ▾">Sản phẩm ▾</a>
                <div class="nav-dropdown-content">
                    <a href="/hub">
                        <span class="dd-icon"><img src="/ArchiH3-Icon_40.png" alt="Hub"></span>
                        <div class="dd-text">
                            <strong data-vi="AH3 Hub" data-en="AH3 Hub">AH3 Hub</strong>
                            <span data-vi="Siêu ứng dụng 3ds Max" data-en="3ds Max Super-app">Siêu ứng dụng 3ds Max</span>
                        </div>
                    </a>
                    <a href="/tree">
                        <span class="dd-icon"><img src="/magictree_icon_48.png" alt="Tree"></span>
                        <div class="dd-text">
                            <strong data-vi="Magic Tree" data-en="Magic Tree">Magic Tree</strong>
                            <span data-vi="Mô phỏng gió &amp; cây cỏ" data-en="Wind &amp; tree simulator">Mô phỏng gió &amp; cây cỏ</span>
                        </div>
                    </a>
                    <a href="/material">
                        <span class="dd-icon"><img src="/magicmat_icon_48.png" alt="Material"></span>
                        <div class="dd-text">
                            <strong data-vi="Magic Material" data-en="Magic Material">Magic Material</strong>
                            <span data-vi="Sinh vật liệu PBR 1-Click" data-en="1-Click PBR generator">Sinh vật liệu PBR 1-Click</span>
                        </div>
                    </a>
                    <a href="/merger">
                        <span class="dd-icon"><img src="/magicmerger_icon_48.png" alt="Merger"></span>
                        <div class="dd-text">
                            <strong data-vi="Magic Merger" data-en="Magic Merger">Magic Merger</strong>
                            <span data-vi="Import &amp; Relink hàng loạt" data-en="Batch merge &amp; relink">Import &amp; Relink hàng loạt</span>
                        </div>
                    </a>
                    <a href="/rebake">
                        <span class="dd-icon"><img src="/magicrebakepro_icon_48.png" alt="ReBake"></span>
                        <div class="dd-text">
                            <strong data-vi="Magic ReBake" data-en="Magic ReBake">Magic ReBake</strong>
                            <span data-vi="Bake map &amp; Decimate tối ưu" data-en="Map baking &amp; decimation">Bake map &amp; Decimate tối ưu</span>
                        </div>
                    </a>
                </div>
            </div>
        <a href="/kindle" data-vi="Bản Kindle" data-en="Kindle Edition" id="kindle-nav-link" style="display: none;">Bản Kindle</a>
        <a href="#author" data-vi="Tác giả" data-en="Author">Tác giả</a>
        <a href="https://youtube.com/@ArchiH3" target="_blank">YouTube</a>
        <div class="lang-toggle">
            <button class="active" onclick="setLang('vi')">VI</button>
            <button onclick="setLang('en')">EN</button>
        </div>
    </div>
</nav>
