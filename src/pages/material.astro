---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="AH3 Magic Material - Standalone Offline PBR Material Generator for 3ds Max">
<Fragment slot="head">

</Fragment>



    <div class="bg-glow"></div>
    <div class="bg-grid"></div>

    <!-- NAV -->
    <Navbar />

    <!-- HERO -->
    <section class="hero">
        <div class="hero-badge" data-vi="100% OFFLINE PBR MATERIAL CREATOR" data-en="100% OFFLINE PBR MATERIAL CREATOR">100% OFFLINE PBR MATERIAL CREATOR</div>
        <h1 data-vi="Khơi nguồn chất liệu.<br><span class='teal'>Tạo map siêu tốc.</span>" data-en="Unleash materials.<br><span class='teal'>Instant PBR setup.</span>"></h1>
        <p class="hero-sub" data-vi="Plugin chuyên biệt tự động tạo trọn bộ bản đồ map PBR (Normal, Roughness, AO, Displacement) từ ảnh 2D và thiết lập vật liệu thông minh cho 3ds Max. Tương thích sâu với V-Ray và Corona, giúp bạn bỏ qua các bước dựng map thủ công nhàm chán." data-en="Specialized plugin to automatically generate a complete set of PBR maps (Normal, Displacement, Roughness, AO) and set up material networks in 3ds Max. Deeply integrated with V-Ray and Corona to eliminate tedious manual workflows."></p>
        <div class="hero-cta">
            <a href="#pricing" class="btn-primary" data-vi="Mua bản quyền — 300k" data-en="Get Lifetime — $12">Mua bản quyền — 300k</a>
            <a href="https://www.facebook.com/ktshuuhoang" target="_blank" onclick="alert('Vui lòng liên hệ DEV qua Facebook để mua hoặc tải bộ cài bản quyền!');" class="btn-outline" data-vi="Tải về" data-en="Download">Tải về</a>
        </div>
    </section>

    <!-- INTERACTIVE DEMO (MOCKUP APP) -->
        <!-- INTERFACE SHOWCASE -->
    <section id="interface"  class="bg-surface">
        <div class="section-label" data-vi="GIAO DIỆN CÔNG CỤ" data-en="INTERFACE SHOWCASE">GIAO DIỆN CÔNG CỤ</div>
        <h2 class="section-title" data-vi="Trực quan, dễ sử dụng" data-en="Visual & Intuitive UI"></h2>
        <p class="section-desc" data-vi="Hình ảnh thực tế giao diện của plugin chạy trực tiếp trong môi trường 3ds Max." data-en="Real screenshot of the plugin user interface running natively inside 3ds Max."></p>
        
        
        <div class="pipeline-wrapper">
            <div class="pipeline-demo" id="magic-pipeline">
                <div class="pl-path pl-path-1"></div>
                <div class="pl-path pl-path-2"></div>
                <div class="pl-path pl-path-3"></div>

                <div class="pl-img"></div>
                <div class="pl-drag-file" id="pl-drag-file"></div>
                <div class="pl-cursor" id="pl-cursor"></div>
                <div class="pl-img-ghost" id="pl-img-ghost"></div>
                <button class="pl-btn" id="pl-btn" onclick="startPipeline()">PROCESS</button>

                
                <div class="pl-term">
                    <div class="pl-term-hdr">
                        <div class="pl-term-dots"><span></span><span></span><span></span></div>
                        <div class="pl-term-tabs">
                            <div class="pl-tab active" id="pl-tab-console">Console</div>
                            <div class="pl-tab" id="pl-tab-settings">Settings</div>
                        </div>
                    </div>
                    <div class="pl-term-body" id="pl-term-out">
                        <div id="pl-view-console">
                            <div class="term-line info">Waiting for input...<span class="term-cursor"></span></div>
                        </div>
                        <div id="pl-view-settings"  class="hidden" style="padding: 10px; font-family: sans-serif;">
                            <div class="pl-setting-row flex items-center"  style="justify-content:space-between; margin-bottom:12px;">
                                <span  style="color:#aaa; font-size:11px;">Brightness</span>
                                <div  class="flex items-center" style="width:150px; gap:8px;">
                                    <div  class="relative" style="flex:1; height:4px; background:#333; border-radius:2px;">
                                        <div id="pl-slide-bright"  style="width:50%; height:100%; background:var(--primary); transition:width 0.8s;"></div>
                                    </div>
                                    <span id="pl-val-bright"  class="text-primary" style="font-size:11px; width:20px; text-align:right;">1.0</span>
                                </div>
                            </div>
                            <div class="pl-setting-row flex items-center"  style="justify-content:space-between; margin-bottom:12px;">
                                <span  style="color:#aaa; font-size:11px;">Contrast</span>
                                <div  class="flex items-center" style="width:150px; gap:8px;">
                                    <div  class="relative" style="flex:1; height:4px; background:#333; border-radius:2px;">
                                        <div id="pl-slide-contrast"  style="width:50%; height:100%; background:var(--primary); transition:width 0.8s;"></div>
                                    </div>
                                    <span id="pl-val-contrast"  class="text-primary" style="font-size:11px; width:20px; text-align:right;">1.0</span>
                                </div>
                            </div>
                            <div class="pl-setting-row flex items-center"  style="justify-content:space-between; margin-bottom:12px;">
                                <span  style="color:#aaa; font-size:11px;">Seamless Blend</span>
                                <div id="pl-switch-seamless" class="pl-switch relative"  style="width:30px; height:16px; background:#333; border-radius:8px; cursor:pointer; transition:background 0.3s;">
                                    <div  class="absolute" style="left:2px; top:2px; width:12px; height:12px; background:#fff; border-radius:50%; transition:left 0.3s;"></div>
                                </div>
                            </div>
                            <div class="pl-setting-row flex items-center"  style="justify-content:space-between; margin-bottom:12px;">
                                <span  style="color:#aaa; font-size:11px;">Auto UVW</span>
                                <div class="pl-switch active relative"  style="width:30px; height:16px; background:var(--primary); border-radius:8px; cursor:pointer; transition:background 0.3s;">
                                    <div  class="absolute" style="left:16px; top:2px; width:12px; height:12px; background:#000; border-radius:50%; transition:left 0.3s;"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="pl-maps" id="pl-maps">
                    <div class="pl-map norm">NRM</div>
                    <div class="pl-map rough">RGH</div>
                    <div class="pl-map ao">AO</div>
                    <div class="pl-map disp">DSP</div>
                </div>

                <div class="pl-sphere" id="pl-sphere"></div>

                <div class="pl-scene">
                    <div class="pl-box" id="pl-box">
                        <div class="pl-face front"></div>
                        <div class="pl-face top"></div>
                        <div class="pl-face right"></div>
                    </div>
                </div>
                
                <div class="pl-ready" id="pl-ready">? MATERIAL ASSIGNED</div>
            </div>
        </div>
        <div class="steps-grid">
            <div class="step-item" id="pl-step-1" onclick="playStep1()">
                <div class="step-num">01</div>
                <h3 data-vi="Kéo &amp; Thả Ảnh" data-en="Drag &amp; Drop Image">Kéo &amp; Thả Ảnh</h3>
                <p data-vi="Kéo ảnh diffuse hoặc file nén zip/rar của vật liệu thả thẳng vào giao diện plugin." data-en="Drag your diffuse texture or a compressed zip/rar archive directly into the plugin window."></p>
            </div>
            <div class="step-item" id="pl-step-2" onclick="playStep2()">
                <div class="step-num">02</div>
                <h3 data-vi="Tinh Chỉnh Cài Đặt" data-en="Adjust Parameters">Tinh Chỉnh Cài Đặt</h3>
                <p data-vi="Bật/tắt chế độ Seamless Gaussian, Auto UVW, chọn loại vật liệu Render và tỉ lệ Tiling mong muốn." data-en="Toggle Seamless Gaussian, Auto UVW, select the rendering target, and adjust your tiling scale."></p>
            </div>
            <div class="step-item" id="pl-step-3" onclick="playStep3()">
                <div class="step-num">03</div>
                <h3 data-vi="Áp dụng 1-Click" data-en="Apply Material">Áp dụng 1-Click</h3>
                <p data-vi="Nhấn nút Generate &amp; Apply. Vật liệu được tự động tạo và gán thẳng lên đối tượng đang chọn." data-en="Click Generate &amp; Apply. The material is instantly built and assigned to the selected 3D object."></p>
            </div>
        </div>
    

    </section>

    <!-- FEATURES -->
    <section id="features">
        <div class="section-label" data-vi="TÍNH NĂNG NỔI BẬT" data-en="KEY FEATURES">TÍNH NĂNG NỔI BẬT</div>
        <h2 class="section-title" data-vi="Tạo vật liệu PBR tự động chỉ với 1-Click" data-en="1-Click Automatic PBR Material Setup"></h2>
        <p class="section-desc" data-vi="Biến bất kỳ ảnh texture đơn lẻ nào thành bộ vật liệu PBR hoàn chỉnh với đầy đủ các kênh phản xạ, độ gồ ghề và chiều sâu chỉ trong vài giây." data-en="Turn any single texture image into a complete PBR material set with reflections, roughness, and depth maps in seconds."></p>
        
        <div class="features-grid">
            <!-- Feature 1 -->
            <div class="feature-card">
                <div class="feature-icon">🧱</div>
                <h3 data-vi="Tự động hóa 1-Click PBR" data-en="1-Click PBR Automation">Tự động hóa 1-Click PBR</h3>
                <p data-vi="Kéo thả 1 ảnh diffuse duy nhất vào. Hệ thống tự động phân tích độ tương phản, sắc độ màu để dựng trọn bộ 4 bản đồ map chất lượng cao: Normal, Displacement, Roughness, AO." data-en="Drag and drop a single diffuse image. The system automatically analyzes contrast and chromatic ranges to generate 4 high-quality maps: Normal, Displacement, Roughness, and AO."></p>
            </div>
            <!-- Feature 2 -->
            <div class="feature-card">
                <div class="feature-icon">🛡️</div>
                <h3 data-vi="Xử lý 100% Offline" data-en="100% Offline Engine">Xử lý 100% Offline</h3>
                <p data-vi="Tốc độ xử lý siêu tốc ngay trên máy tính của bạn mà không cần kết nối internet hay máy chủ bên thứ ba. Bảo mật dữ liệu tuyệt đối, không tải ảnh lên đám mây." data-en="Unmatched processing speed running natively on your hardware without any internet or cloud servers. Keeps your project files completely private, zero cloud uploads."></p>
            </div>
            <!-- Feature 3 -->
            <div class="feature-card">
                <div class="feature-icon">🔍</div>
                <h3 data-vi="Nhận diện thư viện thông minh" data-en="Smart Library Detector">Nhận diện thư viện thông minh</h3>
                <p data-vi="Tự động nhận diện cấu trúc tên của các nhà cung cấp texture lớn (CGAxis, Poliigon, Megascans, ambientCG, Poly Haven). Chỉ tự sinh những bản đồ map còn thiếu để tối ưu hóa thời gian." data-en="Auto-detects naming conventions of major texture vendors (CGAxis, Poliigon, Megascans, ambientCG, Poly Haven). Only generates missing maps to save processing time."></p>
            </div>
            <!-- Feature 4 -->
            <div class="feature-card">
                <div class="feature-icon">🎛️</div>
                <h3 data-vi="Khử vết ghép Seamless" data-en="Seamless Texture Blending">Khử vết ghép Seamless</h3>
                <p data-vi="Xóa bỏ các đường phân tách phân mảnh lộ vân gạch, gỗ bằng bộ lọc mượt mà thông minh. Giúp bạn tạo ra những vật liệu lặp vô hạn (tileable) tự nhiên, chân thực nhất." data-en="Remove visible pattern seam lines using smart blending filters. Helps you create organic, highly realistic tileable materials with ease."></p>
            </div>
            <!-- Feature 5 -->
            <div class="feature-card">
                <div class="feature-icon">⚙️</div>
                <h3 data-vi="Tự động dựng node V-Ray &amp; Corona" data-en="Auto V-Ray &amp; Corona Networks">Tự động dựng node V-Ray &amp; Corona</h3>
                <p data-vi="Tự động nhận diện trình render hiện hành để thiết lập và kết nối mạng lưới node vật liệu vật lý tương ứng chuẩn xác chỉ trong nháy mắt, gán trực tiếp lên đối tượng." data-en="Automatically detects the active renderer to set up and connect physical material node networks accurately, assigning them directly to objects in viewport."></p>
            </div>
            <!-- Feature 6 -->
            <div class="feature-card">
                <div class="feature-icon">📐</div>
                <h3 data-vi="Auto UVW &amp; Điều khiển trực quan" data-en="Auto UVW &amp; Tiling Control">Auto UVW &amp; Điều khiển trực quan</h3>
                <p data-vi="Tích hợp bộ áp nhanh tọa độ UVW Map và tinh chỉnh tỉ lệ lặp (tiling), xoay góc (rotation) vật liệu trực quan trực tiếp trên giao diện plugin mà không cần mở bảng Material Editor." data-en="Integrated quick UVW mapping and controls for tiling and rotation directly in the plugin window, bypassing the need to open the 3ds Max Material Editor."></p>
            </div>
        </div>
    </section>

    

    <!-- PRICING -->
    <section id="pricing">
        <div class="section-label" data-vi="BẢNG GIÁ KHUYẾN MÃI" data-en="LAUNCH PRICE">BẢNG GIÁ KHUYẾN MÃI</div>
        <h2 class="section-title" data-vi="Sở hữu vĩnh viễn. Mua một lần." data-en="Perpetual Pro License. Pay once."></h2>
        <p class="section-desc" data-vi="Cơ hội sở hữu bản quyền Magic Material vĩnh viễn với giá ưu đãi cực lớn nhân dịp mở bán." data-en="Special introductory pricing to own a perpetual license of Magic Material."></p>

        <div class="pricing-section">
            <div class="pricing-grid">
                <!-- Card 1: Standalone -->
                <div class="price-card featured">
                    <div>
                        <div class="price-badge">LIFETIME KEY</div>
                        <h3 data-vi="Magic Material Standalone" data-en="Magic Material Standalone">Magic Material Standalone</h3>
                        <div class="price-amount" data-vi="<del>999.000đ</del> 300.000đ <span>/ vĩnh viễn</span>" data-en="<del>$39</del> $12 <span>/ lifetime</span>"></div>
                        <div class="price-period" data-vi="Khuyến mãi đặc biệt nhân dịp mở bán" data-en="Special introductory discount">Khuyến mãi đặc biệt nhân dịp mở bán</div>
                        
                        <ul class="price-features">
                            <li data-vi="Tự động tạo trọn bộ bản đồ map PBR (Normal, Roughness, AO, Displacement)" data-en="Auto generate full set of PBR maps (Normal, Roughness, AO, Displacement)"></li>
                            <li data-vi="Nhận diện tự động thông minh các loại map có sẵn từ thư viện" data-en="Smart automatic detection of existing maps from vendor libraries"></li>
                            <li data-vi="Thiết lập mạng lưới vật liệu Corona &amp; V-Ray tự động" data-en="Automatic Corona &amp; V-Ray material network setup"></li>
                            <li data-vi="Xử lý khuyết tật phân tách hoa văn (Seamless) nhanh chóng chỉ 1-Click" data-en="1-click seamless texture edge blending"></li>
                            <li data-vi="Bản quyền sử dụng vĩnh viễn, cập nhật miễn phí trọn đời" data-en="Perpetual license with lifetime free updates"></li>
                        </ul>
                    </div>
                    <a href="https://www.facebook.com/ktshuuhoang" target="_blank" class="btn-primary block w-full text-center"  data-vi="Liên hệ mua bản quyền" data-en="Contact to Purchase" style="margin-top:20px;">Liên hệ mua bản quyền</a>
                </div>

                <!-- Card 2: Combo -->
                <div class="price-card featured">
                    <div>
                        <div class="price-badge text-primary"  style="background:var(--primary-glow);">COMBO OFFER</div>
                        <h3 data-vi="Combo Material &amp; Merger" data-en="Combo Material &amp; Merger">Combo Material &amp; Merger</h3>
                        <div class="price-amount" data-vi="<del>1.998.000đ</del> 500.000đ <span>/ vĩnh viễn</span>" data-en="<del>$78</del> $20 <span>/ lifetime</span>"></div>
                        <div class="price-period" data-vi="Gói combo tiết kiệm đặc biệt lên đến 75%" data-en="Special bundle discount - Save up to 75%">Gói combo tiết kiệm đặc biệt lên đến 75%</div>
                        
                        <ul class="price-features">
                            <li data-vi="Giấy phép trọn đời cho <b>CẢ HAI</b> plugin độc lập" data-en="Lifetime keys for <b>BOTH</b> standalone plugins"></li>
                            <li data-vi="Magic Material — tạo map PBR offline 1-click" data-en="Magic Material — 1-click offline PBR generator"></li>
                            <li data-vi="Magic Merger — batch merge và smart-relink texture" data-en="Magic Merger — batch merge &amp; smart texture relinker"></li>
                            <li data-vi="Tương thích 3ds Max 2023-2027+, render Corona / V-Ray" data-en="Supports 3ds Max 2023-2027+, Corona / V-Ray renderers"></li>
                            <li data-vi="Cập nhật miễn phí trọn đời và hỗ trợ ưu tiên" data-en="Lifetime free updates &amp; priority developer support"></li>
                        </ul>
                    </div>
                    <div class="cta-wrapper relative block w-full"  style="margin-top: 20px;">
                        <a href="https://www.facebook.com/ktshuuhoang" target="_blank" class="btn-primary block w-full text-center"  data-vi="Liên hệ mua Combo" data-en="Contact for Combo">Liên hệ mua Combo</a>
                        <span class="bp-dot tl"></span><span class="bp-dot tr"></span><span class="bp-dot bl"></span><span class="bp-dot br"></span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    
    <!-- TUTORIAL / VIDEO -->
    <section id="workflow"  class="bg-surface">
        <div class="section-label" data-vi="HƯỚNG DẪN SỬ DỤNG" data-en="TUTORIAL">HƯỚNG DẪN SỬ DỤNG</div>
        <h2 class="section-title" data-vi="Chi tiết cách dùng Magic Material" data-en="How to use Magic Material"></h2>
        <p class="section-desc" data-vi="Video hướng dẫn chi tiết cách tạo và gán vật liệu tự động trong 3ds Max." data-en="Detailed video tutorial on generating and assigning PBR materials automatically in 3ds Max."></p>
        
        <div class="video-section relative"  style="margin-top: 40px; border-radius: 12px; overflow: hidden; max-width: 1000px; margin-left: auto; margin-right: auto;">
            <div class="video-box" id="featured-video">
            <iframe loading="lazy" id="yt-iframe" width="100%" height="100%" src="https://www.youtube.com/embed/oa2y-5QDA7A?rel=0&modestbranding=1&color=white" title="AH3 Magic Material Demo" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen  class="absolute inset-0"></iframe>
            <a id="yt-fallback" href="https://www.youtube.com/watch?v=oa2y-5QDA7A" target="_blank"  class="hidden absolute inset-0" style="text-decoration:none; cursor:pointer;">
                <img loading="lazy" src="https://img.youtube.com/vi/oa2y-5QDA7A/maxresdefault.jpg" alt="AH3 Magic Material Demo"  onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='0.75'" class="w-full" style="height:100%; object-fit:cover; opacity:0.75; transition:opacity 0.3s;">
                <div  class="absolute inset-0 flex items-center justify-center">
                    <div  class="flex items-center justify-center" style="width:72px; height:72px; border-radius:50%; background:rgba(77, 182, 172, 0.9); box-shadow:0 4px 20px rgba(0,0,0,0.4);">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="#121212"><path d="M8 5v14l11-7z"/></svg>
                    </div>
                </div>
                <div  data-vi="▶ Xem demo trên YouTube" data-en="▶ Watch demo on YouTube" class="absolute" style="bottom:16px; left:16px; font-size:13px; color:rgba(255,255,255,0.7); font-family:'JetBrains Mono',monospace;">▶ Xem demo trên YouTube</div>
            </a>
        </div>
        </div>
    </section>


    <!-- FAQ -->
    <section id="faq"  style="background: var(--bg-dark);">
        <div class="section-label">FAQ</div>
        <h2 class="section-title" data-vi="Giải đáp câu hỏi kỹ thuật" data-en="Frequently Asked Questions"></h2>
        <p class="section-desc" data-vi="Các chi tiết kỹ thuật cốt lõi giúp bạn hiểu rõ về cơ chế hoạt động của Magic Material." data-en="Core technical aspects about how Magic Material functions under the hood."></p>

        <div class="faq-section">
            <div class="faq-grid">
                <div class="faq-item">
                    <h3 data-vi="Plugin tương thích với những trình render và phiên bản 3ds Max nào?" data-en="Which 3ds Max versions and renderers are supported?"></h3>
                    <p data-vi="Magic Material được tối ưu hóa và tương thích hoàn toàn với các phiên bản 3ds Max từ 2023 đến 2027+. Plugin tự động cấu hình và thiết lập mạng lưới node vật liệu chuẩn xác cho cả Corona Renderer (CoronaPhysicalMtl) và V-Ray (VRayMtl) dựa trên thiết lập render hiện tại của bạn." data-en="Magic Material is fully compatible with 3ds Max 2023 up to 2027+. The plugin auto-detects and sets up material networks for both Corona Renderer (CoronaPhysicalMtl) and V-Ray (VRayMtl) based on your active renderer."></p>
                </div>
                <div class="faq-item">
                    <h3 data-vi="Tôi có thể kéo thả những loại file nào vào plugin?" data-en="What files can I drag and drop into the plugin?"></h3>
                    <p data-vi="Bạn có thể kéo thả trực tiếp các định dạng ảnh đơn lẻ (JPG, PNG, TGA), toàn bộ thư mục chứa map của dự án, hoặc thậm chí là các tệp nén (.zip, .rar, .7z). Plugin sẽ tự động phân tích cấu trúc, nhận dạng map có sẵn và trích xuất tài nguyên phù hợp." data-en="You can drag and drop single image formats (JPG, PNG, TGA), entire texture folders, or compressed archives (.zip, .rar, .7z) directly. The plugin automatically parses the files, reads existing maps, and extracts them."></p>
                </div>
                <div class="faq-item">
                    <h3 data-vi="Việc tạo và gán vật liệu có làm thay đổi hay làm hỏng mô hình gốc không?" data-en="Does applying materials risk modifying or ruining the original model?"></h3>
                    <p data-vi="Hoàn toàn không. Magic Material hoạt động theo nguyên tắc an toàn tuyệt đối: bảo toàn nguyên vẹn tọa độ map (UVW coordinates) và cấu trúc lưới gốc của mô hình. Mọi thao tác gán vật liệu đều hỗ trợ hoàn tác 100% bằng phím Ctrl+Z để bạn yên tâm thiết kế." data-en="Not at all. Magic Material works with a strict safety-first approach: original mapping coordinates (UVW) and mesh geometry are 100% preserved. All material application actions support standard Ctrl+Z undo keys to keep your scene completely safe."></p>
                </div>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <Footer />

    <!-- LANGUAGE SWITCH, PIPELINE & INTERACTIVE MOCKUP JS -->
    <script is:inline>

        let currentLang = 'vi';

        function setLang(lang) {
            currentLang = lang;
            document.documentElement.lang = lang;
            document.querySelectorAll('.lang-toggle button').forEach(btn => {
                btn.classList.toggle('active', btn.textContent === lang.toUpperCase());
            });
            document.querySelectorAll('[data-' + lang + ']').forEach(el => {
                const text = el.getAttribute('data-' + lang);
                if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
                    el.placeholder = text;
                } else {
                    el.innerHTML = text;
                }
            });
        }
        
        window.addEventListener('DOMContentLoaded', () => {
            setLang('vi');
        });

        let animTimeout = null;

        function resetAll() {
            if(animTimeout) clearTimeout(animTimeout);
            
            const dragFile = document.getElementById('pl-drag-file');
            const cursor = document.getElementById('pl-cursor');
            const baseImg = document.querySelector('.pl-img');
            const ghostImg = document.getElementById('pl-img-ghost');
            
            dragFile.style.transition = 'none';
            dragFile.style.opacity = '0';
            dragFile.style.left = '-80px';
            dragFile.style.top = '220px';
            dragFile.style.transform = 'none';
            
            cursor.style.transition = 'none';
            cursor.style.opacity = '0';
            cursor.style.left = '200px';
            cursor.style.top = '380px';
            cursor.classList.remove('click-pulse');
            
            baseImg.style.opacity = '0.3';
            ghostImg.classList.remove('fly-in', 'active');
            
            document.getElementById('pl-tab-console').classList.remove('active');
            document.getElementById('pl-tab-settings').classList.remove('active');
            document.getElementById('pl-view-console').style.display = 'none';
            document.getElementById('pl-view-settings').style.display = 'none';
            
            document.getElementById('pl-slide-bright').style.width = '50%';
            document.getElementById('pl-val-bright').innerText = '1.0';
            document.getElementById('pl-slide-contrast').style.width = '50%';
            document.getElementById('pl-val-contrast').innerText = '1.0';
            document.getElementById('pl-switch-seamless').classList.remove('active');
            
            const maps = document.getElementById('pl-maps');
            const mapItems = document.querySelectorAll('.pl-map');
            const sphere = document.getElementById('pl-sphere');
            const box = document.getElementById('pl-box');
            const ready = document.getElementById('pl-ready');
            const termOut = document.getElementById('pl-view-console');
            
            maps.classList.remove('merge', 'pop');
            mapItems.forEach(m => m.classList.remove('pop'));
            sphere.classList.remove('pop', 'fly-box');
            box.classList.remove('textured');
            ready.style.opacity = '0';
            termOut.innerHTML = '<div class="term-line info">Waiting for input...<span class="term-cursor"></span></div>';
            
            for(let i=1; i<=3; i++) {
                const stepCard = document.getElementById('pl-step-' + i);
                if(stepCard) stepCard.classList.remove('active');
            }
        }

        function playStep1() {
            resetAll();
            document.getElementById('pl-step-1').classList.add('active');
            
            const dragFile = document.getElementById('pl-drag-file');
            const cursor = document.getElementById('pl-cursor');
            const baseImg = document.querySelector('.pl-img');
            
            dragFile.style.transition = 'opacity 0.4s';
            cursor.style.transition = 'opacity 0.4s';
            dragFile.style.opacity = '1';
            cursor.style.opacity = '1';
            
            animTimeout = setTimeout(() => {
                cursor.style.transition = 'all 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
                cursor.style.left = '-50px';
                cursor.style.top = '240px';
                
                animTimeout = setTimeout(() => {
                    cursor.classList.add('click-pulse');
                    
                    animTimeout = setTimeout(() => {
                        dragFile.style.transition = 'all 1s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
                        cursor.style.transition = 'all 1s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
                        
                        dragFile.style.left = '70px';
                        dragFile.style.top = '160px';
                        cursor.style.left = '100px';
                        cursor.style.top = '180px';
                        
                        animTimeout = setTimeout(() => {
                            cursor.classList.remove('click-pulse');
                            dragFile.style.transition = 'opacity 0.3s, transform 0.3s';
                            dragFile.style.opacity = '0';
                            dragFile.style.transform = 'scale(0.8)';
                            
                            cursor.style.transition = 'opacity 0.3s';
                            cursor.style.opacity = '0';
                            
                            baseImg.style.transition = 'opacity 0.5s';
                            baseImg.style.opacity = '1';
                            
                            animTimeout = setTimeout(() => {
                                playStep2();
                            }, 1200);
                        }, 1000);
                    }, 400);
                }, 800);
            }, 400);
        }

        function playStep2() {
            if(animTimeout) clearTimeout(animTimeout);
            document.getElementById('pl-step-1').classList.remove('active');
            document.getElementById('pl-step-2').classList.add('active');
            
            document.querySelector('.pl-img').style.opacity = '1';
            
            document.getElementById('pl-tab-settings').classList.add('active');
            document.getElementById('pl-tab-console').classList.remove('active');
            document.getElementById('pl-view-settings').style.display = 'block';
            document.getElementById('pl-view-console').style.display = 'none';
            
            const sliderBright = document.getElementById('pl-slide-bright');
            const valBright = document.getElementById('pl-val-bright');
            const sliderContrast = document.getElementById('pl-slide-contrast');
            const valContrast = document.getElementById('pl-val-contrast');
            const switchSeamless = document.getElementById('pl-switch-seamless');
            
            animTimeout = setTimeout(() => {
                sliderBright.style.width = '75%';
                let bVal = 1.0;
                let bInterval = setInterval(() => {
                    bVal += 0.05;
                    if(bVal >= 1.5) {
                        bVal = 1.5;
                        clearInterval(bInterval);
                    }
                    valBright.innerText = bVal.toFixed(1);
                }, 100);
                
                animTimeout = setTimeout(() => {
                    sliderContrast.style.width = '65%';
                    let cVal = 1.0;
                    let cInterval = setInterval(() => {
                        cVal += 0.05;
                        if(cVal >= 1.3) {
                            cVal = 1.3;
                            clearInterval(cInterval);
                        }
                        valContrast.innerText = cVal.toFixed(1);
                    }, 100);
                    
                    animTimeout = setTimeout(() => {
                        switchSeamless.classList.add('active');
                        
                        animTimeout = setTimeout(() => {
                            playStep3();
                        }, 1500);
                    }, 1000);
                }, 1000);
            }, 500);
        }

        function playStep3() {
            if(animTimeout) clearTimeout(animTimeout);
            document.getElementById('pl-step-2').classList.remove('active');
            document.getElementById('pl-step-3').classList.add('active');
            
            document.querySelector('.pl-img').style.opacity = '1';
            document.getElementById('pl-slide-bright').style.width = '75%';
            document.getElementById('pl-val-bright').innerText = '1.5';
            document.getElementById('pl-slide-contrast').style.width = '65%';
            document.getElementById('pl-val-contrast').innerText = '1.3';
            document.getElementById('pl-switch-seamless').classList.add('active');

            document.getElementById('pl-tab-console').classList.add('active');
            document.getElementById('pl-tab-settings').classList.remove('active');
            document.getElementById('pl-view-console').style.display = 'block';
            document.getElementById('pl-view-settings').style.display = 'none';
            
            const btn = document.getElementById('pl-btn');
            btn.innerText = 'PROCESSING...';
            btn.classList.add('active');

            const ghostImg = document.getElementById('pl-img-ghost');
            const termOut = document.getElementById('pl-view-console');
            const maps = document.getElementById('pl-maps');
            const mapItems = document.querySelectorAll('.pl-map');
            const sphere = document.getElementById('pl-sphere');
            const box = document.getElementById('pl-box');
            const ready = document.getElementById('pl-ready');

            ghostImg.style.transition = 'none';
            ghostImg.classList.remove('fly-in', 'active');
            
            setTimeout(() => {
                ghostImg.classList.add('active');
                void ghostImg.offsetWidth;
                ghostImg.style.transition = 'all 0.7s cubic-bezier(0.4, 0, 0.2, 1)';
                ghostImg.classList.add('fly-in');
            }, 100);

            setTimeout(() => {
                const plCustomTermLines = [
                    { text: "> Initializing Pipeline...", type: "info" },
                    { text: "> Loading source: diffuse.jpg", type: "high" },
                    { text: "[Filter] Applying Brightness (1.5) & Contrast (1.3)", type: "info" },
                    { text: "[Filter] Seamless Gaussian Blend... Active", type: "info" },
                    { text: "[Worker] Normal Map Gen... OK", type: "succ" },
                    { text: "[Worker] Roughness Gen... OK", type: "succ" },
                    { text: "[Worker] AO Gen... OK", type: "succ" },
                    { text: "[Worker] Displacement Gen... OK", type: "succ" },
                    { text: ">> ENGINE COMPLETE.", type: "high" }
                ];
                
                termOut.innerHTML = '';
                let delay = 0;
                plCustomTermLines.forEach((line, index) => {
                    delay += 200;
                    setTimeout(() => {
                        const prevCur = termOut.querySelector('.term-cursor');
                        if(prevCur) prevCur.remove();
                        const div = document.createElement('div');
                        div.className = 'term-line ' + line.type;
                        div.innerHTML = line.text + '<span class="term-cursor"></span>';
                        termOut.appendChild(div);
                        termOut.scrollTop = termOut.scrollHeight;
                        
                        if(index === plCustomTermLines.length - 1) {
                            setTimeout(() => {
                                const finalCur = termOut.querySelector('.term-cursor');
                                if(finalCur) finalCur.remove();
                                
                                maps.classList.add('pop');
                                mapItems.forEach((m, i) => setTimeout(() => m.classList.add('pop'), i * 150));
                                setTimeout(() => {
                                    maps.classList.add('merge');
                                    setTimeout(() => sphere.classList.add('pop'), 300);
                                }, 1400);
                                setTimeout(() => sphere.classList.add('fly-box'), 2400);
                                setTimeout(() => {
                                    box.classList.add('textured');
                                    btn.innerText = 'RESTART';
                                    btn.classList.remove('active');
                                    setTimeout(() => ready.style.opacity = '1', 300);
                                }, 3000);
                            }, 300);
                        }
                    }, delay);
                });
            }, 800);
        }

        function startPipeline() {
            playStep1();
        }
        
        window.addEventListener('DOMContentLoaded', () => {
            const pipeline = document.getElementById('magic-pipeline');
            if (pipeline) {
                let hasRan = false;
                const obs = new IntersectionObserver((entries) => {
                    if (entries[0].isIntersecting && !hasRan) {
                        hasRan = true;
                        setTimeout(startPipeline, 500);
                    }
                }, { threshold: 0.3 });
                obs.observe(pipeline);
            }
        });


        // Mobile navigation dropdown toggle
        document.addEventListener('DOMContentLoaded', () => {
            const trigger = document.querySelector('.dropdown-trigger');
            if (trigger) {
                trigger.addEventListener('click', (e) => {
                    if (window.innerWidth <= 768) {
                        e.preventDefault();
                        const wrapper = trigger.closest('.nav-dropdown-wrapper');
                        if (wrapper) wrapper.classList.toggle('open');
                    }
                });
            }
        });
        </script>
</Layout>