    <!-- LANGUAGE SWITCH & INTERACTIVE MOCKUP JS -->
        <script is:inline>

        // --- INTERACTIVE PIPELINE DEMO TIMELINE LOGIC ---
        let animTimeout;
        let plRunning = false;

        function playStep1() {
            if (animTimeout) clearTimeout(animTimeout);
            
            document.getElementById('pl-step-1').classList.add('active');
            document.getElementById('pl-step-2').classList.remove('active');
            document.getElementById('pl-step-3').classList.remove('active');
            
            // Reset elements
            const file = document.getElementById('pl-drag-file');
            const cursor = document.getElementById('pl-cursor');
            const preview = document.getElementById('pl-preview-box');
            const shield = document.getElementById('pl-shield-box');
            const scene = document.getElementById('pl-scene');
            const box = document.getElementById('pl-box');
            const path1 = document.getElementById('pl-path-1');
            const path2 = document.getElementById('pl-path-2');
            const path3 = document.getElementById('pl-path-3');
            const ready = document.getElementById('pl-ready');
            const term = document.getElementById('pl-term-out');
            
            file.style.opacity = '0';
            file.style.transform = 'translate(0, 0)';
            cursor.style.opacity = '0';
            cursor.style.transform = 'translate(0, 0)';
            preview.classList.remove('pop');
            shield.classList.remove('pop', 'clean', 'scan');
            scene.classList.remove('pop');
            box.classList.remove('textured');
            path1.classList.remove('active');
            path2.classList.remove('active');
            path3.classList.remove('active');
            ready.style.opacity = '0';
            
            // Print Step 1 Logs
            term.innerHTML = '<div class="term-line info">Waiting for input...<span class="term-cursor"></span></div>';
            
            setTimeout(() => {
                file.style.opacity = '1';
                cursor.style.opacity = '1';
                
                // Cursor moves to drag file
                cursor.style.transform = 'translate(-240px, -200px)';
                
                setTimeout(() => {
                    cursor.classList.add('click-pulse');
                    
                    // Drag file with cursor
                    setTimeout(() => {
                        cursor.classList.remove('click-pulse');
                        cursor.style.transform = 'translate(-70px, -170px)';
                        file.style.transform = 'translate(170px, 30px)';
                        
                        setTimeout(() => {
                            cursor.style.opacity = '0';
                            file.style.opacity = '0.5';
                            
                            term.innerHTML = '';
                            const logLines = [
                                { text: "> Drag & Drop event detected.", type: "info" },
                                { text: "> Target package: bed_3d_vray.zip", type: "high" },
                                { text: "[ZipWorker] Decompressing archive...", type: "info" },
                                { text: "[ZipWorker] Extracted bed_3d_vray.max successfully.", type: "succ" }
                            ];
                            
                            let delay = 0;
                            logLines.forEach((line, index) => {
                                delay += 200;
                                setTimeout(() => {
                                    const prevCur = term.querySelector('.term-cursor');
                                    if(prevCur) prevCur.remove();
                                    const div = document.createElement('div');
                                    div.className = 'term-line ' + line.type;
                                    div.innerHTML = line.text + '<span class="term-cursor"></span>';
                                    term.appendChild(div);
                                    term.scrollTop = term.scrollHeight;
                                    
                                    if(index === logLines.length - 1) {
                                        animTimeout = setTimeout(playStep2, 1200);
                                    }
                                }, delay);
                            });
                        }, 800);
                    }, 500);
                }, 800);
            }, 300);
        }

        function playStep2() {
            if (animTimeout) clearTimeout(animTimeout);
            
            document.getElementById('pl-step-1').classList.remove('active');
            document.getElementById('pl-step-2').classList.add('active');
            document.getElementById('pl-step-3').classList.remove('active');
            
            const term = document.getElementById('pl-term-out');
            const preview = document.getElementById('pl-preview-box');
            const shield = document.getElementById('pl-shield-box');
            
            const logLines = [
                { text: "[CompanionFinder] Scanning folder for preview image...", type: "info" },
                { text: "[CompanionFinder] Loaded: bed_3d_vray.jpg", type: "succ" },
                { text: "[Security] Initiating MAXScript malware sweep...", type: "warn" },
                { text: "[Security] Scanning geometry structures...", type: "warn" },
                { text: "[Security] Scan completed: 0 script viruses found. Clean!", type: "succ" }
            ];
            
            let delay = 0;
            logLines.forEach((line, index) => {
                delay += 300;
                setTimeout(() => {
                    const prevCur = term.querySelector('.term-cursor');
                    if(prevCur) prevCur.remove();
                    const div = document.createElement('div');
                    div.className = 'term-line ' + line.type;
                    div.innerHTML = line.text + '<span class="term-cursor"></span>';
                    term.appendChild(div);
                    term.scrollTop = term.scrollHeight;
                    
                    if (index === 1) {
                        preview.classList.add('pop');
                    }
                    if (index === 2) {
                        shield.classList.add('pop', 'scan');
                    }
                    if (index === logLines.length - 1) {
                        shield.classList.remove('scan');
                        shield.classList.add('clean');
                        animTimeout = setTimeout(playStep3, 1500);
                    }
                }, delay);
            });
        }

        function playStep3() {
            if (animTimeout) clearTimeout(animTimeout);
            
            document.getElementById('pl-step-1').classList.remove('active');
            document.getElementById('pl-step-2').classList.remove('active');
            document.getElementById('pl-step-3').classList.add('active');
            
            const term = document.getElementById('pl-term-out');
            const path1 = document.getElementById('pl-path-1');
            const path2 = document.getElementById('pl-path-2');
            const path3 = document.getElementById('pl-path-3');
            const scene = document.getElementById('pl-scene');
            const box = document.getElementById('pl-box');
            const ready = document.getElementById('pl-ready');
            const btn = document.getElementById('pl-btn');
            
            btn.innerText = 'PROCESSING...';
            btn.classList.add('active');
            
            const logLines = [
                { text: "[SmartRelinker] Scanning for missing asset textures...", type: "info" },
                { text: "[SmartRelinker] Matching with local directory index...", type: "info" },
                { text: "[SUCCESS] Relinked: textures/wood_diff.jpg", type: "succ" },
                { text: "[SUCCESS] Relinked: textures/fabric_bump.jpg", type: "succ" },
                { text: "[SceneWorker] Merging bed_3d_vray.max into active scene...", type: "info" },
                { text: "[SceneWorker] Arranging into matrix layout grid...", type: "info" },
                { text: ">> BATCH QUEUE COMPLETED. 100% SUCCESS.", type: "high" }
            ];
            
            let delay = 0;
            logLines.forEach((line, index) => {
                delay += 250;
                setTimeout(() => {
                    const prevCur = term.querySelector('.term-cursor');
                    if(prevCur) prevCur.remove();
                    const div = document.createElement('div');
                    div.className = 'term-line ' + line.type;
                    div.innerHTML = line.text + '<span class="term-cursor"></span>';
                    term.appendChild(div);
                    term.scrollTop = term.scrollHeight;
                    
                    if (index === 0) {
                        path1.classList.add('active');
                    }
                    if (index === 2) {
                        path2.classList.add('active');
                        path3.classList.add('active');
                    }
                    if (index === 4) {
                        scene.classList.add('pop');
                    }
                    if (index === logLines.length - 1) {
                        box.classList.add('textured');
                        setTimeout(() => {
                            ready.style.opacity = '1';
                            btn.innerText = 'RESTART';
                            plRunning = false;
                            btn.classList.remove('active');
                        }, 500);
                    }
                }, delay);
            });
        }

        function startPipeline() {
            if (plRunning) return; // ignore clicks while the sequence is playing
            plRunning = true;
            playStep1();
        }

        // Observer to autotrigger when scrolled in
        window.addEventListener('DOMContentLoaded', () => {
            const pipeline = document.getElementById('magic-pipeline');
            if (pipeline) {
                let hasRan = false;
                const obs = new IntersectionObserver((entries) => {
                    if (entries[0].isIntersecting && !hasRan) {
                        hasRan = true;
                        setTimeout(startPipeline, 500);
                    }
                }, { threshold: 0.3 });
                obs.observe(pipeline);
            }
        });
    
        // Mobile navigation dropdown toggle
        document.addEventListener('DOMContentLoaded', () => {
            const trigger = document.querySelector('.dropdown-trigger');
            if (trigger) {
                trigger.addEventListener('click', (e) => {
                    if (window.innerWidth <= 768) {
                        e.preventDefault();
                        const wrapper = trigger.closest('.nav-dropdown-wrapper');
                        if (wrapper) wrapper.classList.toggle('open');
                    }
                });
            }
        });
        </script>
</Layout>

