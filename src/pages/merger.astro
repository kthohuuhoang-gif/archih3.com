        <h2 class="section-title" data-vi="Trải nghiệm Kéo Thả &amp; Merge thông minh" data-en="Interactive Drag &amp; Merge Pipeline"></h2>
        <p class="section-desc" data-vi="Nhấp &quot;PROCESS MERGE&quot; để trải nghiệm toàn bộ quy trình: Giải nén, Tải ảnh PRV, Quét virus, Sửa đường dẫn map và Merge model." data-en="Click &quot;PROCESS MERGE&quot; to witness the magic: extraction, preview load, virus clean, relink, and grid-merging."></p>
        
        <div class="pipeline-wrapper">
            <div class="pipeline-demo" id="magic-pipeline">
                <div class="pl-path pl-path-1" id="pl-path-1"></div>
                <div class="pl-path pl-path-2" id="pl-path-2"></div>
                <div class="pl-path pl-path-3" id="pl-path-3"></div>

                <!-- Preview Box -->
                <div class="pl-preview-box" id="pl-preview-box">
                    <img src="https://img.youtube.com/vi/sfenH9d4h8I/maxresdefault.jpg" alt="Model Preview">
                </div>

                <!-- Shield Scan Box -->
                <div class="pl-shield-box" id="pl-shield-box">
                    <div class="pl-shield-icon">&#128737;</div>
                </div>

                <!-- Drag File Representation -->
