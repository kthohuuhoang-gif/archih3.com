import Footer from '../components/Footer.astro';
---
<Layout title="AH3 Magic Merger - Standalone Batch Model Importer & Smart Relinker for 3ds Max">
<Fragment slot="head">

</Fragment>



    <div class="bg-glow"></div>
    <div class="bg-grid"></div>

    <!-- NAV -->
    <Navbar />

    <!-- HERO -->
