---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="AH3 Magic ReBake - Standalone Auto Retopology & High-Speed Texture Baker for 3ds Max">
<Fragment slot="head">

</Fragment>



    <div class="bg-glow"></div>
    <div class="bg-grid"></div>

    <!-- NAV -->
    <Navbar />

    <!-- HERO -->
    <section class="hero">
        <div class="hero-badge">STANDALONE RETOPOLOGY & BAKER PLUGIN FOR 3DS MAX</div>
        <h1 data-vi="Lưới Quad sạch mượt.<br>Map vật liệu <span class='teal'>nguyên vẹn</span>." data-en="Clean Quad topology.<br><span class='teal'>Perfect</span> texture transfers."></h1>
        <p class="hero-sub" data-vi="Tự động dựng lại lưới Quad sạch sẽ, mượt mà chỉ với 1-Click từ những mô hình có cấu trúc lưới lộn xộn, đa giác lỗi hoặc file quét 3D. Đồng thời tự động trải UV và truyền map vật liệu gốc sang lưới mới với tốc độ vượt trội." data-en="Automatically reconstruct clean, optimized Quad meshes in 1-Click from messy triangulated geometry, boolean errors, or 3D scans. Concurrently unwraps UVs and bakes original materials to the new mesh with blazing speed."></p>
        <div class="hero-cta">
            <a href="#pricing" class="btn-primary" data-vi="Nhận ưu đãi ra mắt" data-en="Get Launch Deal">Nhận ưu đãi ra mắt</a>
            <a href="#interface" class="btn-outline" data-vi="Thử bản mô phỏng →" data-en="Try Interactive Demo →">Thử bản mô phỏng →</a>
        </div>
    </section>

    <!-- INTERACTIVE DEMO (SIMULATOR) -->
        <!-- INTERFACE SHOWCASE -->
    <section id="interface"  class="bg-surface">
        <div class="interface-grid">
            <div class="interface-text">
                <div class="section-label" data-vi="GIAO DIỆN CÔNG CỤ" data-en="INTERFACE SHOWCASE">GIAO DIỆN CÔNG CỤ</div>
        <h2 class="section-title" data-vi="Trực quan, dễ sử dụng" data-en="Visual & Intuitive UI"></h2>
        <p class="section-desc" data-vi="Hình ảnh thực tế giao diện của plugin chạy trực tiếp trong môi trường 3ds Max." data-en="Real screenshot of the plugin user interface running natively inside 3ds Max."></p>
            </div>
            <div class="interface-visual">
                <img src="interface_magicrebake.png" alt="Plugin Interface"  class="w-full block" style="height: auto; border-radius: 8px; border: 1px solid rgba(255,255,255,0.05);">
            </div>
        </div>
    </section>

    <!-- FEATURES -->
    <section id="features">
        <div class="section-label" data-vi="TÍNH NĂNG NỔI BẬT" data-en="KEY FEATURES">TÍNH NĂNG NỔI BẬT</div>
        <h2 class="section-title" data-vi="Tối ưu lưới và giữ nguyên vật liệu chỉ với 1-Click" data-en="Optimize Mesh &amp; Keep Materials in 1-Click"></h2>
        <p class="section-desc" data-vi="Khắc phục hoàn toàn các lỗi lưới tam giác lộn xộn, mesh nặng từ CAD hoặc file scan, đồng thời tái tạo lại map vật liệu nguyên vẹn trên mô hình mới siêu mượt, siêu nhẹ." data-en="Fix messy triangles, heavy CAD structures, or scan meshes. Regenerate clean topology and perfectly preserve original materials on your new lightweight mesh."></p>
        
        <div class="features-grid">
            <!-- Feature 1 -->
            <div class="feature-card">
                <div class="feature-icon">📐</div>
                <h3 data-vi="Tối ưu hóa lưới Quad sạch mượt" data-en="Clean Quad Retopology">Tối ưu hóa lưới Quad sạch mượt</h3>
                <p data-vi="Thuật toán dựng lưới thông minh giúp chuyển đổi toàn bộ các mô hình có lưới tam giác lỗi, đa giác lộn xộn hoặc tệp quét 3D nặng nề thành lưới Quad (bốn góc) đều tăm tắp, sạch sẽ, mượt mà và cực nhẹ." data-en="Smart reconstruction algorithm converts messy triangles, complex boolean geometry, or heavy 3D scans into clean, regular, and lightweight Quad-based models ready for rendering."></p>
            </div>
            <!-- Feature 2 -->
            <div class="feature-card">
                <div class="feature-icon">⚡</div>
                <h3 data-vi="Truyền map vật liệu siêu tốc" data-en="High-Speed Material Transfer">Truyền map vật liệu siêu tốc</h3>
                <p data-vi="Tích hợp bộ xử lý chuyển đổi map vật liệu thông minh. Tự động chiếu và chụp lại tất cả các kênh màu sắc, độ bóng, độ gồ ghề (Diffuse, Normal, Roughness, AO...) từ vật thể gốc sang vật thể mới chuẩn xác." data-en="Integrated smart texture transfer processor. Automatically maps and bakes all material channels (Diffuse, Normal, Roughness, AO) from the source model onto the optimized target accurately and quickly."></p>
            </div>
            <!-- Feature 3 -->
            <div class="feature-card">
                <div class="feature-icon">🗺️</div>
                <h3 data-vi="Tự động trải UV đồng bộ" data-en="Automatic UV Unwrapping">Tự động trải UV đồng bộ</h3>
                <p data-vi="Tự động tính toán và trải lại hệ tọa độ UV cho lưới Quad mới trực tiếp ngay trong không gian làm việc của 3ds Max. Giúp lưới và map vật liệu khớp khớp hoàn hảo mà không bị lệch hay méo dạng." data-en="Automatically computes and unwraps UV coordinates for the new Quad mesh directly inside 3ds Max, ensuring textures fit perfectly without stretching or scaling distortions."></p>
            </div>
            <!-- Feature 4 -->
            <div class="feature-card">
                <div class="feature-icon">🩹</div>
                <h3 data-vi="Khử răng cưa và lỗi biên UV" data-en="Boundary &amp; Seam Healing">Khử răng cưa và lỗi biên UV</h3>
                <p data-vi="Bộ lọc thông minh tự động phát hiện và tinh chỉnh các vết đứt gãy UV dọc các đường biên cắt. Loại bỏ hoàn toàn hiện tượng vệt răng cưa hoặc lỗi gai nhọn khó chịu ở mép vân vật liệu." data-en="Smart filtering detects and corrects UV texture seams along boundary splits. Completely eliminates unwanted staircasing, artifacts, or spikes at the edges of your materials."></p>
            </div>
            <!-- Feature 5 -->
            <div class="feature-card">
                <div class="feature-icon">🎯</div>
                <h3 data-vi="Quy trình 1-Click chạy ngầm" data-en="1-Click Background Pipeline">Quy trình 1-Click chạy ngầm</h3>
                <p data-vi="Hoàn toàn tự động hóa. Từ khâu xuất mesh nháp, xử lý lưới, trải tọa độ UV đến bake map và gán lại vật liệu hoàn thiện. Bạn chỉ cần nhập số lưới mong muốn và bấm nút, hệ thống sẽ tự lo." data-en="Completely automated workflow. From temp mesh exporting, topology calculation, UV mapping, texture baking, to assigning the final material. Just enter your target count and press one button."></p>
            </div>
            <!-- Feature 6 -->
            <div class="feature-card">
                <div class="feature-icon">🔒</div>
                <h3 data-vi="Xử lý Offline - Bản quyền HWID" data-en="Offline Processing &amp; HWID">Xử lý Offline - Bản quyền HWID</h3>
                <p data-vi="Hoạt động 100% cục bộ trên máy tính của bạn, không tải tệp tin lên cloud, đảm bảo an toàn tuyệt đối cho dữ liệu dự án. Bản quyền trọn đời gắn với ID máy tính, nhận cập nhật tự động miễn phí." data-en="Runs 100% locally on your computer with zero cloud uploads, ensuring absolute privacy for your assets. Lifetime license tied to your HWID with free automatic updates."></p>
            </div>
        </div>
    </section>

    <!-- STEPS / WORKFLOW -->
    <section class="steps-section" id="workflow">
        <div class="section-label" data-vi="QUY TRÌNH XỬ LÝ" data-en="WORKFLOW">QUY TRÌNH XỬ LÝ</div>
        <h2 class="section-title" data-vi="Tối ưu lưới chỉ với 3 bước đơn giản" data-en="Optimize Mesh in 3 Simple Steps"></h2>
        <p class="section-desc" data-vi="Chuyển đổi những model lỗi, nặng nề thành mô hình siêu nhẹ sẵn sàng sử dụng." data-en="Convert heavy and messy models into game-ready, lightweight assets."></p>

        <div class="steps-grid">
            <div class="step-item">
                <div class="step-num">01</div>
                <h3 data-vi="Chọn vật thể &amp; Số lưới" data-en="Select Mesh &amp; Target">Chọn vật thể &amp; Số lưới</h3>
                <p data-vi="Chọn mô hình cần tối ưu lưới trong Max, thiết lập số lượng lưới Quad mong muốn trên thanh trượt." data-en="Select the target model in your scene, and adjust the slider to set your desired target Quad polygon count."></p>
            </div>
            <div class="step-item">
                <div class="step-num">02</div>
                <h3 data-vi="Chạy tối ưu tự động" data-en="Run Auto Retopology">Chạy tối ưu tự động</h3>
                <p data-vi="Nhấn nút Remesh, hệ thống tự động tính toán cấu trúc hình học và tái tạo lại lưới Quad chuẩn chỉ sau vài giây." data-en="Click the Remesh button. The engine computes the geometry layout and reconstructs clean Quad topology instantly."></p>
            </div>
            <div class="step-item">
                <div class="step-num">03</div>
                <h3 data-vi="Tự động trải UV &amp; Bake" data-en="Auto UV &amp; Bake">Tự động trải UV &amp; Bake</h3>
                <p data-vi="Plugin tự động trải UV, chụp map từ vật thể cũ gán sang vật thể mới, thiết lập vật liệu hoàn thiện tự động." data-en="The plugin automatically unwraps UVs, projects textures, and assigns a ready-to-render material back to the scene."></p>
            </div>
        </div>
    </section>

