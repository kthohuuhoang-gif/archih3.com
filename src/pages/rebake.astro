    <!-- FAQ -->
    <section id="faq"  style="background: var(--bg-dark);">
        <div class="section-label">FAQ</div>
        <h2 class="section-title" data-vi="Giải đáp câu hỏi kỹ thuật" data-en="Frequently Asked Questions"></h2>
        <p class="section-desc" data-vi="Các chi tiết cốt lõi giúp bạn hiểu rõ cơ chế hoạt động của Magic ReBake." data-en="Core details helping you understand how Magic ReBake operates under the hood."></p>

        <div class="faq-section"  style="max-width: 900px; margin: 0 auto;">
            <div class="faq-grid"  style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px;">
                <div class="faq-item"  style="background: var(--bg-main); border: 1px solid rgba(85,85,85,0.4); border-radius: 12px; padding: 24px;">
                    <h3  data-vi="Plugin hoạt động như thế nào?" data-en="How does the plugin work?" class="font-semibold text-primary" style="font-size:16px; margin-bottom:10px;"></h3>
                    <p  data-vi="Khi bạn click Remesh, plugin gọi một bộ xử lý hình học chạy ẩn để dựng lại lưới Quad chuẩn. Sau đó, một thuật toán dò tia vector hóa sẽ chạy trên CPU để tính toán và truyền màu sắc, map vật liệu chính xác từ mesh cũ sang mesh mới theo đúng hệ tọa độ UV mới tạo." data-en="When you click Remesh, the plugin invokes a background geometry processor to build the Quad mesh. Then, a vectorized raycasting algorithm runs on your CPU to calculate and project colors and maps from the original mesh to the new UV layout." class="text-muted font-light" style="font-size:14px; line-height:1.7;"></p>
                </div>
                <div class="faq-item"  style="background: var(--bg-main); border: 1px solid rgba(85,85,85,0.4); border-radius: 12px; padding: 24px;">
                    <h3  data-vi="Tính năng trải UV tự động và sửa biên mép hoạt động thế nào?" data-en="How does auto UV unwrap and boundary healing work?" class="font-semibold text-primary" style="font-size:16px; margin-bottom:10px;"></h3>
                    <p  data-vi="Trước khi bake, plugin tự động chạy thuật toán trải phẳng tọa độ map lên lưới Quad mới. Nếu lưới Quad bị đứt gãy dọc đường chéo đa giác tạo ra các seam lỗi, bộ lọc vá biên (Boundary Healer) sẽ tự động khớp các đỉnh biên và là phẳng vùng mép, loại bỏ hoàn toàn các lỗi sọc hoặc gai nhọn." data-en="Before baking, the plugin automatically unwraps mapping coordinates for the new mesh. If the Quad layout splits along polygon diagonals creating bad seams, a Boundary Healer aligns the split vertices to smooth out the edges, removing striping or pixel artifacts." class="text-muted font-light" style="font-size:14px; line-height:1.7;"></p>
                </div>
                <div class="faq-item"  style="background: var(--bg-main); border: 1px solid rgba(85,85,85,0.4); border-radius: 12px; padding: 24px;">
                    <h3  data-vi="Bản quyền HWID hoạt động thế nào? Cập nhật ra sao?" data-en="How does HWID licensing and update work?" class="font-semibold text-primary" style="font-size:16px; margin-bottom:10px;"></h3>
                    <p  data-vi="Giấy phép trọn đời được liên kết với ID phần cứng máy tính (HWID). Mọi tính năng xử lý lưới và bake map hoạt động hoàn toàn offline, đảm bảo tính bảo mật. Mỗi khi có bản vá lỗi hoặc tính năng mới, plugin sẽ tự kiểm tra và tải bản cập nhật tự động (OTA) rất nhanh chóng." data-en="Your perpetual license is linked to your hardware ID (HWID). All retopology and baking features operate offline for maximum security. When a patch or new version is available, the plugin checks and pulls updates automatically (OTA) in seconds." class="text-muted font-light" style="font-size:14px; line-height:1.7;"></p>
                </div>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <Footer />

    <!-- LANGUAGE SWITCH & INTERACTIVE MOCKUP JS -->
        <script is:inline>
        let currentLang = 'vi';

        function setLang(lang) {
            currentLang = lang;
            document.documentElement.lang = lang;
            document.querySelectorAll('.lang-toggle button').forEach(btn => {
                btn.classList.toggle('active', btn.textContent === lang.toUpperCase());
            });
            document.querySelectorAll('[data-' + lang + ']').forEach(el => {
                const text = el.getAttribute('data-' + lang);
                if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
                    el.placeholder = text;
                } else {
                    el.innerHTML = text;
                }
            });
        }
        
        window.addEventListener('DOMContentLoaded', () => {
            setLang('vi');
        });
    
        // Mobile navigation dropdown toggle
        document.addEventListener('DOMContentLoaded', () => {
            const trigger = document.querySelector('.dropdown-trigger');
            if (trigger) {
                trigger.addEventListener('click', (e) => {
                    if (window.innerWidth <= 768) {
                        e.preventDefault();
                        const wrapper = trigger.closest('.nav-dropdown-wrapper');
                        if (wrapper) wrapper.classList.toggle('open');
                    }
                });
            }
        });
        </script>
</Layout>