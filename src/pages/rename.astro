---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="AH3 Magic Rename - UE5 Asset Preparation Tool for 3ds Max">
<Fragment slot="head">

</Fragment>



    <div class="bg-glow"></div>
    <div class="bg-grid"></div>

    <!-- NAV -->
    <Navbar />

    <!-- HERO -->
    <section class="hero">
        <div class="hero-badge" data-vi="3DS MAX TO UNREAL ENGINE 5 PIPELINE OPTIMIZER" data-en="3DS MAX TO UNREAL ENGINE 5 PIPELINE OPTIMIZER">3DS MAX TO UNREAL ENGINE 5 PIPELINE OPTIMIZER</div>
        <h1 data-vi="Chuẩn hóa tài nguyên.<br><span class='teal'>Xuất file UE5 mượt mà.</span>" data-en="Standardize assets.<br><span class='teal'>Smooth UE5 exports.</span>"></h1>
        <p class="hero-sub" data-vi="Plugin Python tự động đổi tên vật thể tương thích ASCII, nhóm group, sửa tên vật liệu và chuẩn hóa hậu tố map kết cấu theo chuẩn đặt tên của Unreal Engine 5. Hỗ trợ backup, rollback và Ctrl+Z hoàn tác an toàn." data-en="Python plugin for 3ds Max to automate asset preparation for Unreal Engine 5. Batch renames objects with ASCII prefixes, auto-groups, renames materials, and standardizes texture suffixes. Built-in backup, rollback, and Ctrl+Z undo."></p>
        <div class="hero-cta">
            <a href="#pricing" class="btn-primary" data-vi="Tải miễn phí (Ver 1)" data-en="Download Free (Ver 1)">Tải miễn phí (Ver 1)</a>
            <a href="https://drive.google.com/drive/folders/1AvvBJZkgq7Xak4YuSv_HIltQkwOFUXoC?usp=drive_link" target="_blank" class="btn-outline" data-vi="Tài liệu" data-en="Documentation">Tài liệu</a>
        </div>
    </section>

    <!-- INTERACTIVE DEMO -->
        <!-- INTERFACE SHOWCASE -->
    <section id="interface"  class="bg-surface">
        <div class="section-label" data-vi="GIAO DIỆN CÔNG CỤ" data-en="INTERFACE SHOWCASE">GIAO DIỆN CÔNG CỤ</div>
        <h2 class="section-title" data-vi="Trực quan, dễ sử dụng" data-en="Visual & Intuitive UI"></h2>
        <p class="section-desc" data-vi="Hình ảnh thực tế giao diện của plugin chạy trực tiếp trong môi trường 3ds Max." data-en="Real screenshot of the plugin user interface running natively inside 3ds Max."></p>
        
        <div class="interface-container">
            <img src="interface_magicrename.png" alt="Plugin Interface"  class="w-full block" style="height: auto; border-radius: 8px; border: 1px solid rgba(255,255,255,0.05);">
        </div>
    </section>

    <!-- FEATURES -->
    <section id="features">
        <div class="section-label" data-vi="TÍNH NĂNG NỔI BẬT" data-en="KEY FEATURES">TÍNH NĂNG NỔI BẬT</div>
        <h2 class="section-title" data-vi="Chuẩn hóa xuất khố sang Unreal Engine 5" data-en="Standardize Exports for Unreal Engine 5"></h2>
        <p class="section-desc" data-vi="Giảm thiểu 90% các lỗi cảnh báo thiếu texture, sai tên hay cấu trúc nhóm lộn xộn khi import Datasmith vào UE5." data-en="Eliminates 90% of missing texture warnings, incorrect file names, or messy hierarchies when importing Datasmith into UE5."></p>
        
        <div class="features-grid">
            <!-- Feature 1 -->
            <div class="feature-card">
                <div class="feature-icon">✏️</div>
                <h3 data-vi="Đổi tên hàng loạt ASCII" data-en="ASCII Batch Renaming">Đổi tên hàng loạt ASCII</h3>
                <p data-vi="Tự động lọc bỏ các ký tự đặc biệt, dấu tiếng Việt để chuyển tên vật thể sang chuẩn mã ASCII an toàn cho Unreal Engine. Tự động thêm tiền tố chỉ định (như SM_, M_, T_)." data-en="Automatically strips special characters and Vietnamese accents, transforming object names into safe ASCII strings with prefixes (e.g. SM_, M_, T_) required by Unreal Engine."></p>
            </div>
            <!-- Feature 2 -->
            <div class="feature-card">
                <div class="feature-icon">📁</div>
                <h3 data-vi="Tự động nhóm (Auto Grouping)" data-en="Auto Grouping">Tự động nhóm (Auto Grouping)</h3>
                <p data-vi="Gom nhóm toàn bộ các bộ phận của model vừa chọn dưới một Group duy nhất có tên tiền tố chung, giúp quản lý phân cấp Outliner trong UE5 cực kỳ gọn gàng." data-en="Groups all components of selected assets under a single group containing the common prefix, ensuring clean Outliner hierarchies in Unreal Engine."></p>
            </div>
            <!-- Feature 3 -->
            <div class="feature-card">
                <div class="feature-icon">🎨</div>
                <h3 data-vi="Đổi tên vật liệu đồng bộ" data-en="Material Synced Renaming">Đổi tên vật liệu đồng bộ</h3>
                <p data-vi="Tự động duyệt và đổi tên các vật liệu (Material) đang được gán trên các đối tượng đã chọn, gán thêm tiền tố vật liệu để đồng bộ hóa quản lý tài nguyên trong game engine." data-en="Automatically maps and renames material instances applied to the selected objects, injecting standard material prefixes to align with asset management guidelines."></p>
            </div>
            <!-- Feature 4 -->
            <div class="feature-card">
                <div class="feature-icon">🏷️</div>
                <h3 data-vi="Gán hậu tố Texture UE5" data-en="UE5 Texture Suffix Mapping">Gán hậu tố Texture UE5</h3>
                <p data-vi="Nhận diện các slot kết cấu chính của vật liệu Corona/V-Ray và đổi tên map tương ứng kèm hậu tố tiêu chuẩn của UE5: Base Color (_BC), Normal (_N), Roughness (_R), Opacity (_O), Emission (_E)." data-en="Identifies main texture channels on Corona/V-Ray materials and copies/renames maps with standard UE5 suffixes: Base Color (_BC), Normal (_N), Roughness (_R), Opacity (_O), Emission (_E)."></p>
            </div>
            <!-- Feature 5 -->
            <div class="feature-card">
                <div class="feature-icon">🔄</div>
                <h3 data-vi="Tự cập nhật Path kết cấu" data-en="Texture Path Auto-Updates">Tự cập nhật Path kết cấu</h3>
                <p data-vi="Tự động định vị, đổi tên tệp tin vật lý trên ổ cứng và trỏ lại đường dẫn kết cấu trong scene 3ds Max. Tích hợp tính năng sao lưu (backup) và phục hồi (rollback) tự động phòng tránh mất file." data-en="Automatically copies and renames physical texture files on disk and updates path references within 3ds Max. Includes automatic backup and rollback routines to prevent file loss."></p>
            </div>
            <!-- Feature 6 -->
            <div class="feature-card">
                <div class="feature-icon">↩️</div>
                <h3 data-vi="Hỗ trợ Ctrl+Z Hoàn tác" data-en="Native Undo Support">Hỗ trợ Ctrl+Z Hoàn tác</h3>
                <p data-vi="Tích hợp sâu với hệ thống Undo/Redo của 3ds Max. Mọi thay đổi về tên vật thể, material, group, hay đường dẫn texture đều có thể khôi phục lại trạng thái cũ ngay lập tức." data-en="Deeply integrated with the native 3ds Max Undo system. Revert all rename, grouping, material, and texture path modifications instantly using standard Ctrl+Z keystrokes."></p>
            </div>
        </div>
    </section>

    <!-- STEPS / WORKFLOW -->
    <section class="steps-section" id="workflow">
        <div class="section-label" data-vi="QUY TRÌNH" data-en="STEPS">QUY TRÌNH</div>
        <h2 class="section-title" data-vi="Sử dụng đơn giản trong 3 bước" data-en="Simple 3-Step Pipeline"></h2>
        <p class="section-desc" data-vi="Chuẩn bị nhanh chóng mô hình của bạn trước khi xuất Datasmith." data-en="Quickly prepare your models before exporting to Datasmith format."></p>

        <div class="steps-grid">
            <div class="step-item">
                <div class="step-num">01</div>
                <h3 data-vi="Chọn vật thể" data-en="Select Objects">Chọn vật thể</h3>
                <p data-vi="Chọn các mô hình, cấu kiện cần chuẩn bị xuất sang Unreal Engine 5 trực tiếp trong scene Max." data-en="Select the 3D meshes and groups that you want to prepare for Unreal Engine 5 in your viewport."></p>
            </div>
            <div class="step-item">
                <div class="step-num">02</div>
                <h3 data-vi="Nhập tiền tố tên" data-en="Enter Prefix">Nhập tiền tố tên</h3>
                <p data-vi="Mở plugin, nhập tiền tố chuẩn ASCII (ví dụ: SM_SofaModern), tùy chọn đổi tên map/material." data-en="Open the plugin, type your ASCII prefix (e.g. SM_SofaModern), and toggle map/material options."></p>
            </div>
            <div class="step-item">
                <div class="step-num">03</div>
                <h3 data-vi="Thực thi &amp; Kiểm tra" data-en="Execute &amp; Export">Thực thi &amp; Kiểm tra</h3>
                <p data-vi="Nhấn nút Rename. Mô hình được đổi tên, gộp nhóm, cập nhật map sẵn sàng để xuất Datasmith." data-en="Click Rename. Objects are renamed, grouped, and texture paths are mapped ready for Datasmith export."></p>
            </div>
        </div>
    </section>

    <!-- PRICING -->
    <section id="pricing">
        <div class="section-label" data-vi="BẢNG GIÁ" data-en="PRICING">BẢNG GIÁ</div>
        <h2 class="section-title" data-vi="Đang được tặng miễn phí" data-en="Currently Offered Free"></h2>
        <p class="section-desc" data-vi="Hỗ trợ quy trình làm việc của bạn mượt mà hơn. Tải về và trải nghiệm hoàn toàn miễn phí cho bản ver 1." data-en="Improving your Unreal Engine workflow. Download and use version 1 completely free of charge."></p>

        <div class="pricing-section">
            <div class="price-card">
                <div class="price-badge">FREE FOR VER 1</div>
                <h3 data-vi="Magic Rename &amp; Grouper" data-en="Magic Rename &amp; Grouper">Magic Rename &amp; Grouper</h3>
                <div class="price-amount" data-vi="<del>100.000đ</del> Free <span>/ vĩnh viễn</span>" data-en="<del>$4.50</del> Free <span>/ lifetime</span>"></div>
                <div class="price-period" data-vi="Khuyến mãi đặc biệt dành tặng cộng đồng" data-en="Special community offer">Khuyến mãi đặc biệt dành tặng cộng đồng</div>
                
                <ul class="price-features">
                    <li data-vi="Đổi tên hàng loạt vật thể chuẩn mã ASCII UE5" data-en="Batch rename objects to UE5-compliant ASCII names"></li>
                    <li data-vi="Tự động đóng gói nhóm (group) theo tên tiền tố chung" data-en="Automatically groups renamed meshes under prefix names"></li>
                    <li data-vi="Đổi tên vật liệu đồng bộ và chuẩn hóa hậu tố map" data-en="Sync material renaming and texture suffix standardizations"></li>
                    <li data-vi="Đổi tên file kết cấu vật lý và cập nhật đường dẫn map" data-en="Renames physical texture files and updates scene path links"></li>
                    <li data-vi="Hỗ trợ đầy đủ phím Ctrl+Z hoàn tác an toàn tuyệt đối" data-en="Full support for native 3ds Max Ctrl+Z undo stack"></li>
                </ul>

                <a href="Download%20Free/AH3_Magic_Rename_v1.0.6.mzp" download class="btn-primary block w-full text-center"  data-vi="Tải về miễn phí" data-en="Download Free">Tải về miễn phí</a>
            </div>
        </div>
    </section>

    <!-- FAQ -->
    <section id="faq"  style="background: var(--bg-dark);">
        <div class="section-label">FAQ</div>
        <h2 class="section-title" data-vi="Giải đáp thắc mắc kỹ thuật" data-en="Frequently Asked Questions"></h2>
        <p class="section-desc" data-vi="Các khía cạnh kỹ thuật khi xuất mô hình 3ds Max sang Unreal Engine 5." data-en="Technical details for exporting 3ds Max models to Unreal Engine 5."></p>

        <div class="faq-section">
            <div class="faq-grid">
                <div class="faq-item">
                    <h3 data-vi="Tại sao việc đặt tên ASCII lại quan trọng khi xuất sang UE5?" data-en="Why is ASCII naming important for UE5 exports?"></h3>
                    <p data-vi="Unreal Engine và các game engine khác không xử lý tốt các tệp tin chứa ký tự tiếng Việt có dấu, khoảng trắng hay ký tự đặc biệt. Việc này thường gây ra lỗi mất liên kết map kết cấu hoặc lỗi không đọc được asset. Magic Rename lọc bỏ hoàn toàn các lỗi này tự động." data-en="Unreal Engine does not support special characters, Vietnamese accents, or whitespaces in asset names. These characters often trigger broken links or unreadable assets. Magic Rename automatically strips them out."></p>
                </div>
                <div class="faq-item">
                    <h3 data-vi="Hậu tố kết cấu chuẩn hóa hoạt động như thế nào?" data-en="How does the standard texture suffix mapping work?"></h3>
                    <p data-vi="Plugin quét vật liệu được gán trên vật thể (Corona/V-Ray), tìm các map kết cấu chính và sao chép/đổi tên file vật lý trên ổ cứng sang chuẩn hậu tố của Unreal: Base Color thành `_BC`, Normal thành `_N`, Roughness thành `_R`, Opacity thành `_O`, và Self-Illumination thành `_E`." data-en="The plugin scans object materials (Corona/V-Ray), extracts main texture maps, and copies/renames physical files on disk with standard Unreal suffixes: Base Color to `_BC`, Normal to `_N`, Roughness to `_R`, Opacity to `_O`, and Self-Illumination to `_E`."></p>
                </div>
                <div class="faq-item">
                    <h3 data-vi="Làm cách nào để tôi khôi phục lại nếu lỡ đổi tên nhầm?" data-en="How do I revert if I make a renaming mistake?"></h3>
                    <p data-vi="Plugin tích hợp sâu với 3ds Max undo system. Bạn chỉ cần nhấn tổ hợp phím Ctrl+Z để hoàn tác toàn bộ chuỗi hành động: đổi tên, group, cập nhật vật liệu và khôi phục lại đường dẫn file kết cấu cũ ngay lập tức." data-en="The plugin integrates with the native 3ds Max undo system. Simply press Ctrl+Z to undo the entire renaming cycle: object names, groups, material updates, and texture paths are restored immediately."></p>
                </div>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <Footer />

    <!-- JS -->
        <script is:inline>
        let currentLang = 'vi';

        function setLang(lang) {
            currentLang = lang;
            document.documentElement.lang = lang;
            document.querySelectorAll('.lang-toggle button').forEach(btn => {
                btn.classList.toggle('active', btn.textContent === lang.toUpperCase());
            });
            document.querySelectorAll('[data-' + lang + ']').forEach(el => {
                const text = el.getAttribute('data-' + lang);
                if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
                    el.placeholder = text;
                } else {
                    el.innerHTML = text;
                }
            });
        }
        
        window.addEventListener('DOMContentLoaded', () => {
            setLang('vi');
        });
    
        // Mobile navigation dropdown toggle
        document.addEventListener('DOMContentLoaded', () => {
            const trigger = document.querySelector('.dropdown-trigger');
            if (trigger) {
                trigger.addEventListener('click', (e) => {
                    if (window.innerWidth <= 768) {
                        e.preventDefault();
                        const wrapper = trigger.closest('.nav-dropdown-wrapper');
                        if (wrapper) wrapper.classList.toggle('open');
                    }
                });
            }
        });
        </script>
</Layout>