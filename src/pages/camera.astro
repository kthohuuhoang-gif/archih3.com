---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Magic Camera — Smart Camera Manager 3ds Max | ArchiH3" description="Plugin quản lý camera chuyên nghiệp. Composition guides, perspective correction, batch render. Sắp ra mắt." ogImage="/og/og-camera.jpg">
<Fragment slot="head">
    <script type="application/ld+json" is:inline>{"@context": "https://schema.org", "@type": "SoftwareApplication", "name": "Magic Camera", "operatingSystem": "Windows", "applicationCategory": "DesignApplication", "applicationSubCategory": "3ds Max Plugin", "description": "Plugin quản lý camera chuyên nghiệp cho 3ds Max. Sắp ra mắt.", "url": "https://archih3.com/camera/", "image": "https://archih3.com/og/og-camera.jpg", "author": {"@type": "Person", "name": "Hồ Hữu Hoàng", "jobTitle": "Architect · 3ds Max Plugin Developer"}, "publisher": {"@type": "Organization", "name": "HKD Dịch vụ Kiến Trúc ArchiH3", "url": "https://archih3.com"}}</script>

</Fragment>



    <div class="bg-glow"></div>
    <div class="bg-grid"></div>

    <!-- NAV -->
    <Navbar />

    <!-- HERO -->
    <section class="hero">
        <div class="hero-badge" data-vi="SMART CAMERA &amp; VIEWPORT STATE MANAGER" data-en="SMART CAMERA &amp; VIEWPORT STATE MANAGER">SMART CAMERA &amp; VIEWPORT STATE MANAGER</div>
        <h1 data-vi="Khung hình hoàn hảo.<br>Quản lý camera <span class='teal'>siêu tốc.</span>" data-en="Perfect framing.<br>High-speed <span class='teal'>camera manager.</span>">Khung hình hoàn hảo.<br>Quản lý camera <span class='teal'>siêu tốc.</span></h1>
        <p class="hero-sub" data-vi="Plugin chuyên biệt tối ưu hóa và chuẩn hóa góc máy trong 3ds Max theo triết lý Scene Manager (Pulze). Tự động quản lý góc máy viewport, căn chỉnh phối cảnh thông minh và render hàng loạt nhanh chóng." data-en="Specialized plugin to optimize and standardize camera set-ups in 3ds Max following the Scene Manager (Pulze) philosophy. Auto-manages viewport camera states, aligns perspective intelligently, and processes batch rendering.">Plugin chuyên biệt tối ưu hóa và chuẩn hóa góc máy trong 3ds Max theo triết lý Scene Manager (Pulze). Tự động quản lý góc máy viewport, căn chỉnh phối cảnh thông minh và render hàng loạt nhanh chóng.</p>
        <div class="hero-cta">
            <a href="#pricing" class="btn-primary" data-vi="Sắp mở bán" data-en="Coming Soon">Sắp mở bán</a>
            <a href="#features" class="btn-outline" data-vi="Xem tính năng" data-en="See Features">Xem tính năng</a>
        </div>
    </section>

    <!-- FEATURES -->
    <section id="features">
        <div class="section-label" data-vi="TÍNH NĂNG NỔI BẬT" data-en="CORE FEATURES">TÍNH NĂNG NỔI BẬT</div>
        <h2 class="section-title" data-vi="Thiết kế dành riêng cho KTS chuyên nghiệp" data-en="Designed for Professional Architects">Thiết kế dành riêng cho KTS chuyên nghiệp</h2>
        <p class="section-desc" data-vi="Giấu đi các bước setup phức tạp, Magic Camera mang lại trải nghiệm quản lý camera mượt mà, trực quan và tối ưu nhất cho render 3D." data-en="Hiding complex backend setup, Magic Camera provides a smooth, visual, and optimized camera management experience for 3D rendering.">Giấu đi các bước setup phức tạp, Magic Camera mang lại trải nghiệm quản lý camera mượt mà, trực quan và tối ưu nhất cho render 3D.</p>
        
        <div class="features-grid">
            <!-- Feature 1 -->
            <div class="feature-card">
                <div class="feat-icon">🖼️</div>
                <h3 class="feat-title" data-vi="Quản Lý Trực Quan" data-en="Visual Gallery Manager">Quản Lý Trực Quan</h3>
                <p class="feat-desc" data-vi="Hệ thống quản lý thông minh danh sách camera trong scene. Tự động thu giữ và hiển thị trạng thái khung hình theo tỷ lệ render thực tế mà không bị méo lệch, giúp bao quát toàn bộ góc máy dự án." data-en="Smart system to manage camera list in your scene. Automatically captures and displays viewport framings matching the exact rendering aspect ratio without distortion.">Hệ thống quản lý thông minh danh sách camera trong scene. Tự động thu giữ và hiển thị trạng thái khung hình theo tỷ lệ render thực tế mà không bị méo lệch, giúp bao quát toàn bộ góc máy dự án.</p>
            </div>
            
            <!-- Feature 2 -->
            <div class="feature-card">
                <div class="feat-icon">📐</div>
                <h3 class="feat-title" data-vi="Lưới Gióng Bố Cục" data-en="Composition Grid Guides">Lưới Gióng Bố Cục</h3>
                <p class="feat-desc" data-vi="Hỗ trợ các đường gióng bố cục mỹ thuật tiêu chuẩn ngay trên viewport 3ds Max: Quy tắc 1/3 (Rule of Thirds), Tỷ lệ vàng (Golden Ratio), Đường chéo và Tâm đối xứng. Giúp kiến trúc sư thiết lập khung hình chuẩn điện ảnh." data-en="Supports professional composition guides directly on the 3ds Max viewport: Rule of Thirds, Golden Ratio, Diagonal, and Center. Set up cinematic framings easily.">Hỗ trợ các đường gióng bố cục mỹ thuật tiêu chuẩn ngay trên viewport 3ds Max: Quy tắc 1/3 (Rule of Thirds), Tỷ lệ vàng (Golden Ratio), Đường chéo và Tâm đối xứng. Giúp kiến trúc sư thiết lập khung hình chuẩn điện ảnh.</p>
            </div>

            <!-- Feature 3 -->
            <div class="feature-card">
                <div class="feat-icon">⚖️</div>
                <h3 class="feat-title" data-vi="Tự Động Căn Phối Cảnh" data-en="Perspective Correction">Tự Động Căn Phối Cảnh</h3>
                <p class="feat-desc" data-vi="Tự động cân bằng góc máy song song mặt đất và khử độ nghiêng tụ dọc. Đưa camera về phối cảnh 2 điểm (2-Point Perspective) hoàn mỹ một cách nhanh chóng, đúng chuẩn nhiếp ảnh kiến trúc." data-en="Automatically balances the camera horizon and corrects vertical perspective tilt. Instantly establishes a perfect 2-point perspective, matching professional architectural photography standards.">Tự động cân bằng góc máy song song mặt đất và khử độ nghiêng tụ dọc. Đưa camera về phối cảnh 2 điểm (2-Point Perspective) hoàn mỹ một cách nhanh chóng, đúng chuẩn nhiếp ảnh kiến trúc.</p>
            </div>

            <!-- Feature 4 -->
            <div class="feature-card">
                <div class="feat-icon">🔍</div>
                <h3 class="feat-title" data-vi="Đồng Bộ Thấu Kính &amp; DoF" data-en="Lens &amp; DoF Control">Đồng Bộ Thấu Kính &amp; DoF</h3>
                <p class="feat-desc" data-vi="Quản lý thống nhất tiêu cự thấu kính, độ sâu trường ảnh (Depth of Field), Clip Near/Far. Tự động tương thích và đồng bộ hóa thông số giữa Physical Camera, V-Ray Camera và Corona Camera." data-en="Unified parameters manager for focal length, Depth of Field (DoF), and Near/Far clipping. Automatically compatible with Physical Camera, V-Ray Camera, and Corona Camera.">Quản lý thống nhất tiêu cự thấu kính, độ sâu trường ảnh (Depth of Field), Clip Near/Far. Tự động tương thích và đồng bộ hóa thông số giữa Physical Camera, V-Ray Camera và Corona Camera.</p>
            </div>

            <!-- Feature 5 -->
            <div class="feature-card">
                <div class="feat-icon">⚙️</div>
                <h3 class="feat-title" data-vi="Xuất Ảnh &amp; Render Hàng Loạt" data-en="Batch Render &amp; Viewport Grab">Xuất Ảnh &amp; Render Hàng Loạt</h3>
                <p class="feat-desc" data-vi="Hỗ trợ xuất hình ảnh viewport nhanh hàng loạt hoặc kết xuất render (Batch Render) đồng thời các camera được chọn. Rút ngắn tối đa thời gian xuất phương án phác thảo thiết kế." data-en="Supports rapid batch viewport grabbing or batch rendering for multiple selected cameras. Minimizes design option exporting times significantly.">Hỗ trợ xuất hình ảnh viewport nhanh hàng loạt hoặc kết xuất render (Batch Render) đồng thời các camera được chọn. Rút ngắn tối đa thời gian xuất phương án phác thảo thiết kế.</p>
            </div>

            <!-- Feature 6 -->
            <div class="feature-card">
                <div class="feat-icon">🚀</div>
                <h3 class="feat-title" data-vi="Trợ Lý Bố Cục AI (Sắp ra mắt)" data-en="AI Composition Assistant (Upcoming)">Trợ Lý Bố Cục AI (Sắp ra mắt)</h3>
                <p class="feat-desc" data-vi="Tính năng sắp ra mắt hỗ trợ phân tích không gian bằng trí tuệ nhân tạo. Tự động định vị và đề xuất vị trí đặt camera, góc ống kính tối ưu nhất dựa trên hướng chính của các chủ thể 3D." data-en="Upcoming feature utilizing AI spatial analysis. Automatically suggests best camera positioning and focal length based on 3D geometry layout in the scene.">Tính năng sắp ra mắt hỗ trợ phân tích không gian bằng trí tuệ nhân tạo. Tự động định vị và đề xuất vị trí đặt camera, góc ống kính tối ưu nhất dựa trên hướng chính của các chủ thể 3D.</p>
            </div>
        </div>
    </section>

    <!-- PRICING -->
    <section id="pricing">
        <div class="section-label" data-vi="BẢNG GIÁ" data-en="PRICING">BẢNG GIÁ</div>
        <h2 class="section-title" data-vi="Lựa chọn gói bản quyền phù hợp" data-en="Choose Your License Model">Lựa chọn gói bản quyền phù hợp</h2>
        <p class="section-desc" data-vi="Đầu tư một lần tối ưu hóa trọn đời quy trình đặt camera và kết xuất phối cảnh 3D." data-en="One-time investment to permanently optimize your camera framing and 3D rendering workflow.">Đầu tư một lần tối ưu hóa trọn đời quy trình đặt camera và kết xuất phối cảnh 3D.</p>

        <div class="pricing-grid"  style="grid-template-columns: 1fr; max-width: 600px;">
            <!-- Promo Card -->
            <div class="pricing-card featured text-center items-center" >
                <div class="price-badge" data-vi="SẮP MỞ BÁN" data-en="COMING SOON">SẮP MỞ BÁN</div>
                <h3 class="price-title">Magic Camera</h3>
                <p class="price-sub" data-vi="Đăng ký nhận thông báo ngày mở bán" data-en="Register for opening day notifications">Đăng ký nhận thông báo ngày mở bán</p>
                <div class="price-num text-primary font-semibold"  data-vi="Giá ưu đãi ra mắt 200.000đ sẽ được công bố khi mở bán — theo dõi Facebook để nhận thông báo." data-en="A 200,000đ launch price will be announced at release — follow Facebook to get notified." style="font-size: clamp(16px, 3vw, 24px); line-height: 1.4; margin: 16px 0;">Giá ưu đãi ra mắt 200.000đ sẽ được công bố khi mở bán — theo dõi Facebook để nhận thông báo.</div>
                <ul class="price-features text-left mb-8" >
                    <li data-vi="Đầy đủ tính năng quản lý thấu kính &amp; DoF" data-en="Full camera lens &amp; DoF manager">Đầy đủ tính năng quản lý thấu kính &amp; DoF</li>
                    <li data-vi="Căn phối cảnh 2 điểm trực giao" data-en="Auto horizon level &amp; 2-point perspective">Căn phối cảnh 2 điểm trực giao</li>
                    <li data-vi="Chụp nhanh và quản lý an toàn viewport" data-en="Batch viewport grabbing &amp; rendering">Chụp nhanh và quản lý an toàn viewport</li>
                    <li data-vi="Cập nhật miễn phí tính năng AI trợ lý bố cục" data-en="Free update to upcoming AI composition assistant">Cập nhật miễn phí tính năng AI trợ lý bố cục</li>
                </ul>
                <a href="https://www.facebook.com/ktshuuhoang" target="_blank" rel="noopener" class="btn-primary" data-vi="Liên hệ DEV qua Facebook" data-en="Contact DEV via Facebook">Liên hệ DEV qua Facebook</a>
            </div>
        </div>
    </section>

    <!-- FAQ -->
    <section id="faq"  class="bg-surface">
        <div class="section-label" data-vi="CÂU HỎI THƯỜNG GẶP" data-en="FAQ">CÂU HỎI THƯỜNG GẶP</div>
        <h2 class="section-title" data-vi="Giải đáp thắc mắc" data-en="Frequently Asked Questions">Giải đáp thắc mắc</h2>
        
        <div class="faq-container">
            <div class="faq-item">
                <div class="faq-q" data-vi="Plugin hỗ trợ những loại camera nào trong 3ds Max?" data-en="Which camera types are supported by the plugin?">Plugin hỗ trợ những loại camera nào trong 3ds Max?</div>
                <div class="faq-a" data-vi="Magic Camera tương thích hoàn hảo với Standard Target Camera, Physical Camera, V-Ray Physical Camera và Corona Camera. Công cụ sẽ tự động nhận diện thấu kính đang chọn để nạp các thuộc tính phù hợp." data-en="Magic Camera is fully compatible with Standard Target Camera, Physical Camera, V-Ray Physical Camera, and Corona Camera. The tool automatically adapts properties to the selected camera type.">Magic Camera tương thích hoàn hảo với Standard Target Camera, Physical Camera, V-Ray Physical Camera và Corona Camera. Công cụ sẽ tự động nhận diện thấu kính đang chọn để nạp các thuộc tính phù hợp.</div>
            </div>
            <div class="faq-item">
                <div class="faq-q" data-vi="Sau khi cài đặt có cần kết nối Internet để sử dụng không?" data-en="Does the plugin require an active internet connection?">Sau khi cài đặt có cần kết nối Internet để sử dụng không?</div>
                <div class="faq-a" data-vi="Không. Mọi tính năng tính toán bố cục và quản lý camera đều chạy 100% offline trực tiếp trên máy của bạn, bảo mật hoàn toàn dữ liệu dự án." data-en="No. All camera management features run 100% offline on your local machine, keeping project data completely secure.">Không. Mọi tính năng tính toán bố cục và quản lý camera đều chạy 100% offline trực tiếp trên máy của bạn, bảo mật hoàn toàn dữ liệu dự án.</div>
            </div>
            <div class="faq-item">
                <div class="faq-q" data-vi="Làm thế nào để nhận mật khẩu cài đặt/giải nén?" data-en="How do I get the setup/unzip password?">Làm thế nào để nhận mật khẩu cài đặt/giải nén?</div>
                <div class="faq-a" data-vi="Mật khẩu cài đặt sẽ được cung cấp trực tiếp khi bạn liên hệ mua bản quyền từ nhà phát triển. DEV sẽ hỗ trợ bạn cấu hình và kích hoạt sử dụng một cách nhanh chóng." data-en="The setup password will be directly provided when you purchase a license from the developer. The DEV will assist you in configuring and activating the tool quickly.">Mật khẩu cài đặt sẽ được cung cấp trực tiếp khi bạn liên hệ mua bản quyền từ nhà phát triển. DEV sẽ hỗ trợ bạn cấu hình và kích hoạt sử dụng một cách nhanh chóng.</div>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <Footer />

    <script is:inline>
    
        // Mobile navigation dropdown toggle
        document.addEventListener('DOMContentLoaded', () => {
            const trigger = document.querySelector('.dropdown-trigger');
            if (trigger) {
                trigger.addEventListener('click', (e) => {
                    if (window.innerWidth <= 768) {
                        e.preventDefault();
                        const wrapper = trigger.closest('.nav-dropdown-wrapper');
                        if (wrapper) wrapper.classList.toggle('open');
                    }
                });
            }
        });
        </script>
</Layout>

<style>

        /* BUTTONS */
        .btn-primary {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 12px 28px; background: var(--primary);
            color: #121212; font-weight: 600; font-size: 14px;
            border: none; border-radius: 6px;
            text-decoration: none; cursor: pointer; transition: all 0.25s;
        }
        .btn-primary:hover {
            background: var(--primary-hover); transform: translateY(-1px);
            box-shadow: 0 4px 20px rgba(77, 182, 172, 0.3);
        }
        .btn-outline {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 12px 28px; background: transparent;
            color: var(--text); font-weight: 400; font-size: 14px;
            border: var(--border-dash) !important; border-radius: 6px;
            text-decoration: none; cursor: pointer; transition: all 0.25s;
        }
        .btn-outline:hover { border-color: var(--primary) !important; color: var(--primary); }

        /* HERO */
        .hero {
            padding: 140px 24px 60px;
            display: flex; flex-direction: column; align-items: center;
            text-align: center; position: relative;
        }
        .hero-badge {
            display: inline-block; font-family: 'JetBrains Mono', monospace;
            font-size: 12px; color: var(--primary);
            border: 1px solid rgba(77,182,172,0.3);
            padding: 6px 16px; border-radius: 20px;
            margin-bottom: 24px; background: var(--primary-glow); letter-spacing: 1px;
        }
        .hero h1 {
            font-size: clamp(36px, 5vw, 60px); font-weight: 700;
            line-height: 1.1; margin-bottom: 20px; letter-spacing: -2px;
        }
        .hero h1 .teal { color: var(--primary); }
        .hero-sub {
            font-size: 18px; color: var(--text-secondary);
            max-width: 680px; margin: 0 auto 32px; font-weight: 300;
        }
        .hero-cta { display: flex; gap: 16px; flex-wrap: wrap; }

        /* SECTIONS */
        section { padding: 80px 24px; }

        /* FEATURES */
        .features-grid {
            max-width: 1100px; margin: 0 auto;
            display: grid; grid-template-columns: repeat(auto-fit, minmax(min(320px, 100%), 1fr));
            gap: 24px;
        }
        .feature-card {
            background: var(--bg-main); border: var(--border-dash) !important;
            padding: 32px; border-radius: 12px !important; transition: all 0.3s;
        }
        .feature-card:hover {
            border-color: var(--primary) !important; transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(0,0,0,0.3);
        }
        .feat-icon {
            font-size: 28px; width: 56px; height: 56px;
            border-radius: 10px; background: rgba(77,182,172,0.05);
            display: flex; align-items: center; color: var(--primary); margin-bottom: 24px;
            border: 1px solid rgba(77,182,172,0.15);
        }
        .feat-title { font-size: 20px; font-weight: 600; margin-bottom: 12px; }
        .feat-desc { font-size: 14px; color: var(--text-secondary); line-height: 1.6; font-weight: 300; }

        /* PRICING */
        .pricing-grid {
            max-width: 900px; margin: 0 auto;
            display: grid; grid-template-columns: repeat(auto-fit, minmax(min(320px, 100%), 1fr));
            gap: 32px; }
        .pricing-card {
            background: var(--bg-main); border: var(--border-dash) !important;
            border-radius: 12px !important; padding: 48px 32px;
            position: relative; display: flex; flex-direction: column;
            transition: all 0.3s;
        }
        .pricing-card:hover {
            border-color: var(--primary) !important; transform: translateY(-4px);
            box-shadow: 0 12px 40px rgba(0,0,0,0.4);
        }
        .pricing-card.featured {
            border-color: var(--primary) !important;
            background: linear-gradient(180deg, rgba(77, 182, 172, 0.05) 0%, var(--bg-main) 100%);
        }
        .price-badge {
            position: absolute; top: 24px; right: 24px;
            background: rgba(77,182,172,0.15); color: var(--primary);
            font-size: 11px; font-weight: 600; padding: 4px 10px;
            border-radius: 12px; border: 1px solid rgba(77,182,172,0.3);
            text-transform: uppercase; letter-spacing: 0.5px;
        }
        .price-title { font-size: 24px; font-weight: 600; margin-bottom: 8px; }
        .price-sub { font-size: 14px; color: var(--text-secondary); margin-bottom: 24px; font-weight: 300; }
        .price-num { font-size: 48px; font-weight: 700; color: #fff; margin-bottom: 24px; line-height: 1; }
        .price-num span { font-size: 16px; font-weight: 400; color: var(--text-secondary); }
        .price-features {
            list-style: none; display: flex; flex-direction: column;
            gap: 12px; margin-bottom: 40px; flex: 1;
        }
        .price-features li {
            font-size: 14px; color: var(--text-secondary);
            display: flex; align-items: center; gap: 10px;
        }
        .price-features li::before {
            content: "✓"; color: var(--primary); font-weight: bold;
        }
        .price-cta {
            display: block; width: 100%; text-align: center;
            padding: 14px 0; border-radius: 8px; font-size: 14px;
            font-weight: 600; text-decoration: none; transition: all 0.25s;
            cursor: pointer;
        }
        .price-cta.primary { background: var(--primary); color: #121212; }
        .price-cta.primary:hover { background: var(--primary-hover); }
        .price-cta.outline { border: var(--border-dash) !important; color: var(--text); }
        .price-cta.outline:hover { border-color: var(--primary) !important; color: var(--primary); }

        /* FAQ */
        .faq-container { max-width: 800px; margin: 0 auto; display: flex; flex-direction: column; gap: 16px; }
        .faq-item {
            background: var(--bg-main); border: var(--border-dash) !important;
