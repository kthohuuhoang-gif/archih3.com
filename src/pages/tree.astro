---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Magic Tree — Mô phỏng gió cây cỏ 3ds Max | ArchiH3" description="Plugin mô phỏng gió vật lý 4 lớp cho cây cỏ. Hỗ trợ Maxtree, Globe Plants, Cosmos. Corona & V-Ray proxy.">
<Fragment slot="head">

</Fragment>



    <div class="bg-glow"></div>
    <div class="bg-grid"></div>

    <!-- NAV -->
    <Navbar />

    <!-- HERO -->
    <section class="hero">
        <div class="hero-badge" data-vi="PHYSICS-BASED WIND SIMULATION FOR 3DS MAX" data-en="PHYSICS-BASED WIND SIMULATION FOR 3DS MAX">PHYSICS-BASED WIND SIMULATION FOR 3DS MAX</div>
        <h1 data-vi="Thổi hồn vào cây cỏ.<br><span class='green'>Render nhẹ tênh.</span>" data-en="Breeze in your viewports.<br><span class='green'>Lightweight renders.</span>">Thổi hồn vào cây cỏ.<br><span class='green'>Render nhẹ tênh.</span></h1>
        <p class="hero-sub" data-vi="Plugin chuyên biệt tạo chuyển động gió 4 lớp chân thực và tự động hóa tối ưu cho cây cối trong 3ds Max. Tương thích sâu với Corona/V-Ray Proxy, loại bỏ hoàn toàn lag giật viewport." data-en="Specialized plugin to generate realistic 4-layer wind simulations and automatic optimizations for 3ds Max vegetation. Deeply integrated with Corona/V-Ray proxies to completely eliminate viewport lag.">Plugin chuyên biệt tạo chuyển động gió 4 lớp chân thực và tự động hóa tối ưu cho cây cối trong 3ds Max. Tương thích sâu với Corona/V-Ray Proxy, loại bỏ hoàn toàn lag giật viewport.</p>
        <div class="hero-cta">
            <a href="#pricing" class="btn-primary" data-vi="Mua bản quyền — 450k" data-en="Get Pro Lifetime — $17">Mua bản quyền — 450k</a>
            <a href="https://www.facebook.com/ktshuuhoang" target="_blank" rel="noopener" onclick="alert('Vui lòng liên hệ DEV qua Facebook để mua hoặc tải bộ cài bản quyền!');" class="btn-outline" data-vi="Tải về" data-en="Download">Tải về</a>
        </div>
    </section>

    <!-- STEPS / WORKFLOW -->
    <section class="steps-section" id="workflow">
        <div class="section-label" data-vi="QUY TRÌNH" data-en="STEPS">QUY TRÌNH</div>
        <h2 class="section-title" data-vi="3 bước biến cây tĩnh thành cây động" data-en="3 steps from static to dynamic">3 bước biến cây tĩnh thành cây động</h2>
        <p class="section-desc" data-vi="Tự động hóa hoàn toàn các công đoạn phức tạp, tối ưu hóa tối đa thời gian thao tác scene." data-en="Fully automated pipelines to minimize manual tasks and maximize scene productivity.">Tự động hóa hoàn toàn các công đoạn phức tạp, tối ưu hóa tối đa thời gian thao tác scene.</p>

        
        

        
        <!-- INTERACTIVE SVG SIMULATION -->
        <div class="tree-sim-container" data-state="1" data-aos="fade-up">
            <div class="tree-sim-canvas">
                <svg viewBox="0 -50 400 450" xmlns="http://www.w3.org/2000/svg">
                    <g class="tree-wrapper">
                        <!-- BONES (State 2) -->
                        <g class="hifi-bone-group">
                            <line class="hifi-bone" x1="200" y1="380" x2="208" y2="280" />
                            <line class="hifi-bone" x1="208" y1="280" x2="204" y2="180" />
                            <line class="hifi-bone" x1="204" y1="180" x2="200" y2="100" />
                            
                            <line class="hifi-bone" x1="200" y1="100" x2="100" y2="150" />
                            <line class="hifi-bone" x1="200" y1="100" x2="300" y2="150" />
                            <line class="hifi-bone" x1="200" y1="100" x2="120" y2="60" />
                            <line class="hifi-bone" x1="200" y1="100" x2="280" y2="60" />
                            <line class="hifi-bone" x1="200" y1="100" x2="150" y2="20" />
                            <line class="hifi-bone" x1="200" y1="100" x2="250" y2="20" />
                        </g>

                        <!-- TRUNK -->
                        <!-- A thicker curved path representing the coconut trunk -->
                        <path class="hifi-trunk" d="M200,380 Q220,240 200,100" />
                        
                        
                        <!-- COCONUTS -->
                        <g class="coconuts-group" transform="translate(200, 100)">
                            <circle class="hifi-coconut" cx="-20" cy="5" r="14" />
                            <circle class="hifi-coconut" cx="20" cy="5" r="14" />
                            <circle class="hifi-coconut" cx="0" cy="18" r="16" />
                        </g>
                        
                        <!-- LEAVES CANOPY -->

                        <g class="leaves-group" transform="translate(200, 100)">
                            <!-- Bottom Leaves (Blue in State 2) -->
                            <path class="hifi-leaf hifi-leaf-bottom l-b-l" d="M0,0 C-30,-20 -100,-20 -170,40" />
                            <path class="hifi-leaf hifi-leaf-bottom l-b-r" d="M0,0 C30,-20 100,-20 170,40" />
                            
                            <!-- Mid Leaves (Green in State 2) -->
                            <path class="hifi-leaf hifi-leaf-mid l-m-l" d="M0,0 C-40,-50 -120,-60 -180,0" />
                            <path class="hifi-leaf hifi-leaf-mid l-m-r" d="M0,0 C40,-50 120,-60 180,0" />
                            
                            <!-- Top Leaves (Yellow in State 2) -->
                            <path class="hifi-leaf hifi-leaf-top l-t-l" d="M0,0 C-20,-90 -80,-130 -110,-90" />
                            <path class="hifi-leaf hifi-leaf-top l-t-r" d="M0,0 C20,-90 80,-130 110,-90" />
                        </g>

                        <!-- NODES (State 2) -->
                        <g class="hifi-node-group">
                            <circle class="hifi-node" cx="200" cy="380" r="6" />
                            <circle class="hifi-node" cx="208" cy="280" r="5" />
                            <circle class="hifi-node" cx="204" cy="180" r="5" />
                            <circle class="hifi-node" cx="200" cy="100" r="7" />
                            
                            <circle class="hifi-node" cx="100" cy="150" r="4" />
                            <circle class="hifi-node" cx="300" cy="150" r="4" />
                            <circle class="hifi-node" cx="120" cy="60" r="4" />
                            <circle class="hifi-node" cx="280" cy="60" r="4" />
                            <circle class="hifi-node" cx="150" cy="20" r="4" />
                            <circle class="hifi-node" cx="250" cy="20" r="4" />
                        </g>
                    </g>
                </svg>
            </div>
            <div class="tree-sim-controls">
                <button class="sim-btn active" id="sim-btn-1" onclick="setTreeState(1)" data-vi="1. Model tĩnh" data-en="1. Static Model"><div class="sim-color-dot"></div>1. Model tĩnh</button>
                <button class="sim-btn" id="sim-btn-2" onclick="setTreeState(2)" data-vi="2. Dò tìm sinh học (Rig)" data-en="2. Bio-Rigging"><div class="sim-color-dot"></div>2. Dò tìm sinh học (Rig)</button>
                <button class="sim-btn" id="sim-btn-3" onclick="setTreeState(3)" data-vi="3. Đón gió (Wind Loop)" data-en="3. Wind Loop"><div class="sim-color-dot"></div>3. Đón gió (Wind Loop)</button>
            </div>
        </div>

        <div class="steps-grid">
            <div class="step-item" id="step-desc-1">
                <div class="step-num">01</div>
                <h3 data-vi="Chọn cây hoặc Proxy" data-en="Select Foliage/Proxy">Chọn cây hoặc Proxy</h3>
                <p data-vi="Chọn các mô hình cây 3D hoặc file Proxy của Corona/V-Ray trực tiếp trong scene 3ds Max." data-en="Select any 3D plant models or V-Ray/Corona proxy objects directly in your 3ds Max viewports.">Chọn các mô hình cây 3D hoặc file Proxy của Corona/V-Ray trực tiếp trong scene 3ds Max.</p>
            </div>
            <div class="step-item" id="step-desc-2">
                <div class="step-num">02</div>
                <h3 data-vi="Bake gió 1-Click" data-en="1-Click Wind Bake">Bake gió 1-Click</h3>
                <p data-vi="Nhấn nút gán gió. Magic Tree tự động phân tích cấu trúc, nhận diện chiều cao và áp dụng cấu hình chuyển động tối ưu cho từng loại cây." data-en="Click apply. Magic Tree automatically analyzes the structure, detects plant height, and applies the most optimized wind behavior.">Nhấn nút gán gió. Magic Tree tự động phân tích cấu trúc, nhận diện chiều cao và áp dụng cấu hình chuyển động tối ưu cho từng loại cây.</p>
            </div>
            <div class="step-item" id="step-desc-3">
                <div class="step-num">03</div>
                <h3 data-vi="Realtime Tweak & Render" data-en="Realtime Tweak & Render">Realtime Tweak & Render</h3>
                <p data-vi="Tinh chỉnh hướng gió, chu kỳ lặp và 13 thông số gió trực tiếp thời gian thực, sau đó render chuỗi ảnh động." data-en="Fine-tune wind directions, loops, and 13 detailed parameters with realtime updates, then render your wind-swayed animations.">Tinh chỉnh hướng gió, chu kỳ lặp và 13 thông số gió trực tiếp thời gian thực, sau đó render chuỗi ảnh động.</p>
            </div>
        </div>
    </section>


    <!-- FEATURES -->
    <section id="features">
        <div class="section-label" data-vi="TÍNH NĂNG NỔI BẬT" data-en="KEY FEATURES">TÍNH NĂNG NỔI BẬT</div>
        <h2 class="section-title" data-vi="Mô phỏng gió tự nhiên chỉ với 1-Click" data-en="1-Click Natural Wind Simulation">Mô phỏng gió tự nhiên chỉ với 1-Click</h2>
        <p class="section-desc" data-vi="Biến rừng cây tĩnh lặng thành chuyển động tự nhiên trong gió chỉ với vài cú click chuột, siêu nhẹ và cực kỳ nhanh chóng." data-en="Turn static forests into natural sways with just a few clicks, lightweight and extremely fast.">Biến rừng cây tĩnh lặng thành chuyển động tự nhiên trong gió chỉ với vài cú click chuột, siêu nhẹ và cực kỳ nhanh chóng.</p>
        
        <div class="features-grid">
            <!-- Feature 1 -->
            <div class="feature-card">
                <div class="feature-icon">🍃</div>
                <h3 data-vi="Mô phỏng chuyển động gió 4 lớp" data-en="4-Layer Dynamic Sway">Mô phỏng gió 4 lớp</h3>
                <p data-vi="Tác động đồng thời lên 4 cấp độ cành lá: chuyển động rung lá, độ xoắn tự nhiên của tán, độ uốn cong chân thực của thân cây và độ đung đưa nhẹ của hoa/quả giúp tạo cảm giác chuyển động đa chiều chân thực nhất." data-en="Simulates movements on 4 levels: leaf flutter, natural canopy twist, realistic trunk bending, and gentle fruit/flower swaying for the most realistic multi-dimensional motion.">Tác động đồng thời lên 4 cấp độ cành lá: chuyển động rung lá, độ xoắn tự nhiên của tán, độ uốn cong chân thực của thân cây và độ đung đưa nhẹ của hoa/quả giúp tạo cảm giác chuyển động đa chiều chân thực nhất.</p>
            </div>
            <!-- Feature 2 -->
            <div class="feature-card">
                <div class="feature-icon">🌿</div>
                <h3 data-vi="Hỗ trợ mọi thư viện cây lớn" data-en="Full Library Support">Hỗ trợ mọi thư viện cây lớn</h3>
                <p data-vi="Tương thích hoàn hảo với các thư viện cây phổ biến nhất như Maxtree, Globe Plants, Chaos Cosmos và bất kỳ file Proxy nào của V-Ray, Corona, giúp bạn làm việc trực tiếp và nhanh chóng." data-en="Perfectly compatible with the most popular vegetation libraries such as Maxtree, Globe Plants, Chaos Cosmos, and any V-Ray or Corona proxies, allowing direct and fast workflows.">Tương thích hoàn hảo với các thư viện cây phổ biến nhất như Maxtree, Globe Plants, Chaos Cosmos và bất kỳ file Proxy nào của V-Ray, Corona, giúp bạn làm việc trực tiếp và nhanh chóng.</p>
            </div>
            <!-- Feature 3 -->
            <div class="feature-card">
                <div class="feature-icon">⚡</div>
                <h3 data-vi="Tự động hóa & Thao tác cực nhanh" data-en="1-Click Auto Pipeline">Tự động hóa & Thao tác cực nhanh</h3>
                <p data-vi="Không cần thiết lập thủ công tốn thời gian. Magic Tree tự động nhận diện chiều cao, tối ưu hóa proxy và gán các thông số gió phù hợp giúp bạn hoàn thành công việc chỉ trong vài giây." data-en="Zero manual setups required. Magic Tree automatically detects plant heights, optimizes proxies, and applies wind presets in seconds.">Không cần thiết lập thủ công tốn thời gian. Magic Tree tự động nhận diện chiều cao, tối ưu hóa proxy và gán các thông số gió phù hợp giúp bạn hoàn thành công việc chỉ trong vài giây.</p>
            </div>
            <!-- Feature 4 -->
            <div class="feature-card">
                <div class="feature-icon">🎲</div>
                <h3 data-vi="Lệch pha tự nhiên & An toàn tuyệt đối" data-en="Randomized Phase & Safe Undo">Lệch pha tự nhiên & An toàn tuyệt đối</h3>
                <p data-vi="Mỗi cây tự động lệch pha ngẫu nhiên để khi rải rừng cây lớn (Forest Pack, Chaos Scatter) không bị đồng điệu máy móc. Hỗ trợ Ctrl+Z hoàn tác 100% cực kỳ an tâm khi thiết kế." data-en="Generates unique random phase offsets per tree to avoid repetitive patterns in scattered forests. Fully supports clean Ctrl+Z undo actions to keep your scene completely safe.">Mỗi cây tự động lệch pha ngẫu nhiên để khi rải rừng cây lớn (Forest Pack, Chaos Scatter) không bị đồng điệu máy móc. Hỗ trợ Ctrl+Z hoàn tác 100% cực kỳ an tâm khi thiết kế.</p>
            </div>
            <!-- Feature 5 -->
            <div class="feature-card">
                <div class="feature-icon">⚙️</div>
                <h3 data-vi="Tối ưu Render & Dung lượng" data-en="Optimized File Size & Render">Tối ưu Render & Dung lượng</h3>
                <p data-vi="Cơ chế bake keyframe thông minh tự động tối ưu hóa số lượng keyframe của modifier, giữ cho file scene 3ds Max cực nhẹ và không làm tăng thời gian render khi chạy camera." data-en="Smart keyframe baking automatically optimizes modifier keyframes, keeping 3ds Max file sizes lightweight and maintaining fast render times.">Cơ chế bake keyframe thông minh tự động tối ưu hóa số lượng keyframe của modifier, giữ cho file scene 3ds Max cực nhẹ và không làm tăng thời gian render khi chạy camera.</p>
            </div>
            <!-- Feature 6 -->
            <div class="feature-card">
                <div class="feature-icon">🎛️</div>
                <h3 data-vi="Hệ thống Preset & Tùy biến" data-en="Wind Presets & Customization">Hệ thống Preset & Tùy biến</h3>
                <p data-vi="Cung cấp sẵn các mẫu preset gió chuẩn (Nhẹ, Vừa, Bão) và hơn 13 thanh slider tinh chỉnh chuyên sâu giúp bạn dễ dàng lưu trữ, quản lý cấu hình gió cho từng loại dự án." data-en="Comes with built-in wind presets (Breeze, Medium, Storm) and 13+ advanced sliders to easily adjust, save, and manage custom wind behaviors.">Cung cấp sẵn các mẫu preset gió chuẩn (Nhẹ, Vừa, Bão) và hơn 13 thanh slider tinh chỉnh chuyên sâu giúp bạn dễ dàng lưu trữ, quản lý cấu hình gió cho từng loại dự án.</p>
            </div>
        </div>
    </section>

    <!-- WIND PHYSICS VISUALIZATION -->
        <!-- INTERFACE SHOWCASE -->
    <section id="interface"  class="bg-surface">
        <div class="interface-grid">
            <div class="interface-text">
                <div class="section-label" data-vi="GIAO DIỆN CÔNG CỤ" data-en="INTERFACE SHOWCASE">GIAO DIỆN CÔNG CỤ</div>
        <h2 class="section-title" data-vi="Trực quan, dễ sử dụng" data-en="Visual & Intuitive UI">Trực quan, dễ sử dụng</h2>
        <p class="section-desc" data-vi="Hình ảnh thực tế giao diện của plugin chạy trực tiếp trong môi trường 3ds Max." data-en="Real screenshot of the plugin user interface running natively inside 3ds Max.">Hình ảnh thực tế giao diện của plugin chạy trực tiếp trong môi trường 3ds Max.</p>
            </div>
            <div class="interface-visual">
                <img src="/interface_magictree.png" alt="Plugin Interface"  class="w-full block" style="height: auto; border-radius: 8px; border: 1px solid rgba(255,255,255,0.05);">
            </div>
        </div>
    </section>

    <!-- TREE CATEGORIES -->
    <section id="categories"  class="bg-surface">
        <div class="section-label" data-vi="NHẬN DẠNG SINH HỌC" data-en="BIO-STRUCTURE DETECTION">NHẬN DẠNG SINH HỌC</div>
        <h2 class="section-title" data-vi="Tự động nhận dạng 6 nhóm thực vật" data-en="Automatic detection of 6 plant types">Tự động nhận dạng 6 nhóm thực vật</h2>
        <p class="section-desc" data-vi="Hệ thống tự động phân tích cấu trúc cây và từ khóa vật liệu để áp dụng các thiết lập mô phỏng gió phù hợp nhất cho từng nhóm thực vật." data-en="Magic Tree automatically analyzes plant structures and materials to apply the most natural wind behavior for each category.">Hệ thống tự động phân tích cấu trúc cây và từ khóa vật liệu để áp dụng các thiết lập mô phỏng gió phù hợp nhất cho từng nhóm thực vật.</p>

        <div class="cat-table-container">
            <table>
                <thead>
                    <tr>
                        <th data-vi="Nhóm cây" data-en="Plant Class">Nhóm cây</th>
                        <th data-vi="Thực vật tiêu biểu" data-en="Representative Species">Thực vật tiêu biểu</th>
                        <th data-vi="Đặc tính chuyển động gió" data-en="Wind Sway Behavior">Đặc tính chuyển động gió</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><span class="cat-badge">SMALL</span></td>
                        <td data-vi="Cỏ nền, rêu bụi, hoa dại thấp sát đất" data-en="Lawn grass, moss, low groundcover wildflowers">Cỏ nền, rêu bụi, hoa dại thấp sát đất</td>
                        <td data-vi="Dao động tần số cao cành lá sát đất, thân cỏ uốn cong mềm dẻo theo làn gió mặt đất." data-en="High-frequency leaf flutter close to ground, flexible grass blade bending.">Dao động tần số cao cành lá sát đất, thân cỏ uốn cong mềm dẻo theo làn gió mặt đất.</td>
                    </tr>
                    <tr>
                        <td><span class="cat-badge">SHRUB</span></td>
                        <td data-vi="Cây bụi tầm thấp, hoa hồng bụi, cây trang trí" data-en="Low shrubs, garden roses, ornamental low plants">Cây bụi tầm thấp, hoa hồng bụi, cây trang trí</td>
                        <td data-vi="Rung lắc nhẹ nhàng phần cành ngọn tán bụi, neo giữ ổn định phần gốc gỗ sát mặt đất." data-en="Gentle upper branch sways, sturdy root anchoring near the soil line.">Rung lắc nhẹ nhàng phần cành ngọn tán bụi, neo giữ ổn định phần gốc gỗ sát mặt đất.</td>
                    </tr>
                    <tr>
                        <td><span class="cat-badge">TREE</span></td>
                        <td data-vi="Cây đô thị tầm trung, cây bóng mát công cộng" data-en="Medium urban trees, public park shade trees">Cây đô thị tầm trung, cây bóng mát công cộng</td>
                        <td data-vi="Cân bằng tự nhiên giữa độ uốn cong của thân chính và nhịp rung lắc của các tầng tán lá." data-en="Balanced natural sway between main trunk deflection and foliage vibration.">Cân bằng tự nhiên giữa độ uốn cong của thân chính và nhịp rung lắc của các tầng tán lá.</td>
                    </tr>
                    <tr>
                        <td><span class="cat-badge">BIG</span></td>
                        <td data-vi="Cây cổ thụ lớn, xà cừ, bàng, đa cổ thụ" data-en="Large heritage trees, giant banyans, ancient maples">Cây cổ thụ lớn, xà cừ, bàng, đa cổ thụ</td>
                        <td data-vi="Dao động chậm rãi và uy nghi của thân gỗ lớn, các cành nhánh nặng trĩu lay động biên độ lớn." data-en="Slow, majestic sways of heavy timber trunks, large branches waving.">Dao động chậm rãi và uy nghi của thân gỗ lớn, các cành nhánh nặng trĩu lay động biên độ lớn.</td>
                    </tr>
