                                        <ellipse cx="155" cy="75" rx="6" ry="18" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <!-- Cylinder -->
                                        <ellipse cx="20" cy="85" rx="10" ry="3" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <ellipse cx="20" cy="98" rx="10" ry="3" fill="none" stroke="#4db6ac" stroke-width="0.8" />
