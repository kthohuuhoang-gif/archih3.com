---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Showcase from '../components/Showcase.astro';
import Footer from '../components/Footer.astro';
import AssetTiles from '../components/AssetTiles.astro';
---
<Layout title="AH3 Tools — Plugin AI & Tự động hóa 3ds Max | ArchiH3" description="Bộ công cụ plugin 3ds Max chuyên nghiệp: AH3 Hub, Magic Material, Magic Merger, Magic Tree và hơn thế. Phát triển bởi HKD Dịch vụ Kiến Trúc ArchiH3." ogImage="/og/og-default.jpg">
<Fragment slot="head">
    <script type="application/ld+json" is:inline>{"@context": "https://schema.org", "@type": "Organization", "name": "HKD Dịch vụ Kiến Trúc ArchiH3", "alternateName": "AH3 Tools", "url": "https://archih3.com", "logo": "https://archih3.com/logo.png", "email": "hohuuhoang@archih3.com", "founder": {"@type": "Person", "name": "Hồ Hữu Hoàng", "jobTitle": "Architect · 3ds Max Plugin Developer"}, "sameAs": ["https://youtube.com/@ArchiH3", "https://www.facebook.com/ktshuuhoang"]}</script>
    <script type="application/ld+json" is:inline>{"@context": "https://schema.org", "@type": "WebSite", "name": "AH3 Tools", "url": "https://archih3.com", "inLanguage": ["vi", "en"]}</script>

</Fragment>



    <div class="bg-glow"></div>
    <div class="bg-grid"></div>

    <!-- NAV -->
    <Navbar />

    <!-- HERO -->
    <section class="hero" id="main-hero">
        
        <div class="orb-wrapper orb-wrapper-1" id="orb-w-1"><div class="orb orb-1"></div></div>
        <div class="orb-wrapper orb-wrapper-2" id="orb-w-2"><div class="orb orb-2"></div></div>
        <div class="hero-content" data-aos="zoom-in" data-aos-duration="1000">
            <div class="hero-badge" data-vi="AI & TỰ ĐỘNG HÓA KIẾN TRÚC" data-en="AI & ARCHITECTURE AUTOMATION">AI & TỰ ĐỘNG HÓA KIẾN TRÚC</div>
            <h1 data-vi="Bạn thiết kế.<br><span class='teal'>AH3 lo phần còn lại.</span>" data-en="You design.<br><span class='teal'>AH3 does the rest.</span>">Bạn thiết kế.<br><span class='teal'>AH3 lo phần còn lại.</span></h1>
            <p class="hero-sub" data-vi="Bộ plugin AI & tự động hóa cho 3ds Max — viết bởi một kiến trúc sư đang hành nghề, cho chính những việc lặp lại đang ăn mòn giờ thiết kế của bạn." data-en="AI & automation plugins for 3ds Max — built by a practicing architect, for the repetitive work that eats your design hours.">Bộ plugin AI & tự động hóa cho 3ds Max — viết bởi một kiến trúc sư đang hành nghề, cho chính những việc lặp lại đang ăn mòn giờ thiết kế của bạn.</p>
            <div class="hero-cta-group">
                <div class="cta-wrapper relative"  style="display: inline-flex; margin-top: 0;">
                    <a href="#products" class="hero-cta-btn hero-cta-primary" data-vi="Khám phá bộ công cụ" data-en="Explore the toolkit">Khám phá bộ công cụ</a>
                    <span class="bp-dot tl"></span><span class="bp-dot tr"></span><span class="bp-dot bl"></span><span class="bp-dot br"></span>
                </div>
                <a href="https://www.youtube.com/@ArchiH3" target="_blank" rel="noopener" class="hero-cta-btn hero-cta-secondary" data-vi="Xem Demo" data-en="▶ Watch Video"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px"><circle cx="12" cy="12" r="10"></circle><polygon points="10 8 16 12 10 16 10 8"></polygon></svg> Xem Demo</a>
            </div>
        </div>
    </section>

    <!-- SOCIAL PROOF STATS -->
    <div class="stats-bar" data-aos="fade-up" data-aos-delay="100">
        <div class="stat-item">
            <span class="stat-number" data-vi="10+" data-en="10+">10+</span>
            <span class="stat-label" data-vi="Plugins phát triển" data-en="Plugins developed">Plugins phát triển</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <span class="stat-number" data-vi="100+" data-en="100+">100+</span>
            <span class="stat-label" data-vi="Kiến trúc sư tin dùng" data-en="Architects trust us">Kiến trúc sư tin dùng</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <span class="stat-number" data-vi="4+" data-en="4+">4+</span>
            <span class="stat-label" data-vi="Năm phát triển" data-en="Years of development">Năm phát triển</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <span class="stat-number" data-vi="100%" data-en="100%">100%</span>
            <span class="stat-label" data-vi="Made in Vietnam 🇻🇳" data-en="Made in Vietnam 🇻🇳">Made in Vietnam 🇻🇳</span>
        </div>
    </div>

    
    <!-- SIMULATIONS MARQUEE -->
    <div class="marquee-container" data-aos="fade-up" data-aos-delay="200">
        <div class="marquee-track track-1">
            
            <a href="/hub" class="marquee-item">
                <div class="marquee-title">AH3 Hub<span class="detail-link-btn">Xem chi tiết</span></div>
                <div class="mini-sim-box" id="hub-sim-mq1">
                    <div class="sim-viewport">
                                <svg class="sim-svg" viewBox="0 0 200 112.5">
                                    <defs>
                                        <linearGradient id="hub-sky-grad" x1="0" y1="0" x2="0" y2="1">
                                            <stop offset="0%" stop-color="#0d1b2a"/><stop offset="100%" stop-color="#1b263b"/>
                                        </linearGradient>
                                        <linearGradient id="hub-wall-grad" x1="0" y1="0" x2="0" y2="1">
                                            <stop offset="0%" stop-color="#37474f"/><stop offset="100%" stop-color="#263238"/>
                                        </linearGradient>
                                        <linearGradient id="hub-window-glow" x1="0" y1="0" x2="0" y2="1">
                                            <stop offset="0%" stop-color="#ffd54f"/><stop offset="100%" stop-color="#ff8f00"/>
                                        </linearGradient>
                                        <linearGradient id="hub-light-spill" x1="0" y1="0" x2="0" y2="1">
                                            <stop offset="0%" stop-color="#ffd54f"/><stop offset="100%" stop-color="transparent"/>
                                        </linearGradient>
                                        <linearGradient id="hub-metal-grad" x1="0" y1="0" x2="1" y2="0">
                                            <stop offset="0%" stop-color="#78909c"/><stop offset="50%" stop-color="#cfd8dc"/><stop offset="100%" stop-color="#546e7a"/>
                                        </linearGradient>
                                        <radialGradient id="hub-gold-sphere" cx="0.35" cy="0.3" r="0.9">
                                            <stop offset="0%" stop-color="#ffe082"/><stop offset="55%" stop-color="#d69e2e"/><stop offset="100%" stop-color="#8d6e63"/>
                                        </radialGradient>
                                    </defs>
                                    
                                    <!-- 1. Wireframe Sketch (Base) -->
                                    <g class="wf-lines"  style="transition: opacity 0.4s;">
                                        <!-- House Block -->
                                        <rect x="35" y="45" width="85" height="55" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <rect x="45" y="60" width="65" height="40" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <polygon points="30,45 125,45 105,25 50,25" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <!-- Sphere -->
                                        <circle cx="155" cy="75" r="18" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <ellipse cx="155" cy="75" rx="18" ry="6" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <ellipse cx="155" cy="75" rx="6" ry="18" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <!-- Cylinder -->
                                        <ellipse cx="20" cy="85" rx="10" ry="3" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <ellipse cx="20" cy="98" rx="10" ry="3" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <line x1="10" y1="85" x2="10" y2="98" stroke="#4db6ac" stroke-width="0.8" />
                                        <line x1="30" y1="85" x2="30" y2="98" stroke="#4db6ac" stroke-width="0.8" />
                                    </g>

                                    <!-- 2. Flat Color Stage (Shading) -->
                                    <g class="colored-view pointer-events-none"  style="transition: opacity 0.5s;">
                                        <rect x="0" y="0" width="200" height="112.5" fill="#111" />
                                        <rect x="35" y="45" width="85" height="55" fill="#2d3748" />
                                        <rect x="45" y="60" width="65" height="40" fill="#319795" />
                                        <polygon points="30,45 125,45 105,25 50,25" fill="#4a5568" />
                                        <circle cx="155" cy="75" r="18" fill="#d69e2e" />
                                        <rect x="10" y="85" width="20" height="13" fill="#718096" />
                                    </g>

                                    <!-- 3. Final Neural Render (ClipPath controlled) -->
                                    <g class="rendered-view pointer-events-none" clip-path="url(#hub-clip-1)" >
                                        <!-- Sky -->
                                        <rect x="0" y="0" width="200" height="112.5" fill="url(#hub-sky-grad)" />
                                        <!-- Distant stars -->
                                        <circle cx="50" cy="25" r="0.6" fill="#fff" opacity="0.6" />
                                        <circle cx="95" cy="20" r="0.6" fill="#fff" opacity="0.8" />
                                        <!-- House Body -->
                                        <rect x="35" y="45" width="85" height="55" fill="url(#hub-wall-grad)" />
                                        <polygon points="30,45 125,45 105,25 50,25" fill="#1f2937" />
                                        <!-- Glowing Windows -->
                                        <rect x="45" y="60" width="65" height="40" fill="url(#hub-window-glow)" />
                                        <!-- Window Grids -->
                                        <line x1="77.5" y1="60" x2="77.5" y2="100" stroke="#111" stroke-width="0.8" />
                                        <line x1="45" y1="80" x2="110" y2="80" stroke="#111" stroke-width="0.8" />
                                        <!-- Light spill on floor -->
                                        <polygon points="45,100 110,100 120,112 35,112" fill="url(#hub-light-spill)" opacity="0.6" />
                                        <!-- Metallic Cylinder -->
                                        <rect x="10" y="85" width="20" height="13" fill="url(#hub-metal-grad)" />
                                        <ellipse cx="20" cy="85" rx="10" ry="3" fill="#90a4ae" />
                                        <!-- Gold Sphere -->
                                        <circle cx="155" cy="75" r="18" fill="url(#hub-gold-sphere)" />
                                    </g>
                                    <line class="scan-line" x1="0" y1="0" x2="0" y2="112.5" stroke="var(--primary)" stroke-width="1.5"   />
                                    <clipPath id="hub-clip-1"><rect id="hub-clip-rect-1" x="0" y="0" width="0" height="112.5" /></clipPath>
                                </svg>
                            
                    </div>
                </div>
            </a>
            <a href="/tree" class="marquee-item">
                <div class="marquee-title">Magic Tree<span class="detail-link-btn">Xem chi tiết</span></div>
                <div class="mini-sim-box" id="tree-sim-mq1">
