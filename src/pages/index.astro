        function adjustTreeWind(slider) {
            const box = slider.closest('.mini-sim-box');
            const label = box.querySelector('.wind-label');
            const val = parseInt(slider.value);
            
            let speed = '0s';
            let strength = '0deg';
            let text = 'None';
            let color = '#888';
            
            if (val === 1) {
                speed = '3s';
                strength = '2deg';
                text = 'Breeze';
                color = 'var(--green)';
            } else if (val === 2) {
                speed = '1.5s';
                strength = '6deg';
                text = 'Windy';
                color = '#ffa726';
            } else if (val === 3) {
                speed = '0.6s';
                strength = '12deg';
                text = 'Storm';
                color = '#e57373';
            }
            
            const wrapper = box.querySelector('.mini-tree-wrapper');
            if (wrapper) {
                if (val === 0) {
                    wrapper.style.animation = 'none';
                } else {
                    wrapper.style.animation = `tree-sway ${speed} ease-in-out infinite`;
                    wrapper.style.setProperty('--wind-strength', strength);
                }
            }
            if (label) {
                label.innerHTML = text;
                label.style.color = color;
            }
        }

        function runMaterialSim(btn) {
            if (btn.classList.contains('active')) return;
            btn.classList.add('active');
            const originalText = btn.innerHTML;
            btn.innerHTML = 'GENERATING PBR...';
            const box = btn.closest('.mini-sim-box');
            const file = box.querySelector('.mini-file');
            const grid = box.querySelector('.mini-maps-grid');
            const scene = box.querySelector('.mini-scene');
