                                    </g>
                                    <line class="scan-line" x1="0" y1="0" x2="0" y2="112.5" stroke="var(--primary)" stroke-width="1.5"   />
                                    <clipPath id="hub-clip-2"><rect id="hub-clip-rect-2" x="0" y="0" width="0" height="112.5" /></clipPath>
                                </svg>
                            
                    </div>
                </div>
            </a>
            <a href="/tree" class="marquee-item" aria-hidden="true" tabindex="-1">
                <div class="marquee-title">Magic Tree<span class="detail-link-btn">Xem chi tiết</span></div>
                <div class="mini-sim-box" id="tree-sim-mq2">
