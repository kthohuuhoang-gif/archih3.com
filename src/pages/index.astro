---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="AH3 Tools — Plugin AI & Tự động hóa 3ds Max | ArchiH3" description="Bộ công cụ plugin 3ds Max chuyên nghiệp: AH3 Hub, Magic Material, Magic Merger, Magic Tree và hơn thế. Phát triển bởi Hộ Kinh Doanh Dịch vụ Kiến Trúc ArchiH3.">
<Fragment slot="head">

</Fragment>

    <!-- AOS CSS -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">


    <div class="bg-glow"></div>
    <div class="bg-grid"></div>

    <!-- NAV -->
    <Navbar />

    <!-- HERO -->
    <section class="hero" id="main-hero">
        
        <div class="orb-wrapper orb-wrapper-1" id="orb-w-1"><div class="orb orb-1"></div></div>
        <div class="orb-wrapper orb-wrapper-2" id="orb-w-2"><div class="orb orb-2"></div></div>
        <div class="hero-content" data-aos="zoom-in" data-aos-duration="1000">
            <div class="hero-badge" data-vi="AI & TỰ ĐỘNG HÓA KIẾN TRÚC" data-en="AI & ARCHITECTURE AUTOMATION">AI & TỰ ĐỘNG HÓA KIẾN TRÚC</div>
            <h1 data-vi="Chào mừng tới <span class='teal'>AH3 Tools</span>" data-en="Welcome to <span class='teal'>AH3 Tools</span>">Chào mừng tới <span class='teal'>AH3 Tools</span></h1>
            <p class="hero-sub" data-vi="Cổng thông tin và các sản phẩm plugin tối ưu quy trình thiết kế 3ds Max được phát triển bởi Kiến trúc sư Hồ Hữu Hoàng." data-en="Architecture design optimization plugins & tools for 3ds Max developed by Architect Ho Huu Hoang.">Cổng thông tin và các sản phẩm plugin tối ưu quy trình thiết kế 3ds Max được phát triển bởi Kiến trúc sư Hồ Hữu Hoàng.</p>
            <div class="hero-cta-group">
                <div class="cta-wrapper relative"  style="display: inline-flex; margin-top: 0;">
                    <a href="#products" class="hero-cta-btn hero-cta-primary" data-vi="Khám phá ngay" data-en="Explore Now">Khám phá ngay</a>
                    <span class="bp-dot tl"></span><span class="bp-dot tr"></span><span class="bp-dot bl"></span><span class="bp-dot br"></span>
                </div>
                <a href="https://www.youtube.com/@ArchiH3" target="_blank" class="hero-cta-btn hero-cta-secondary" data-vi="▶ Xem Video" data-en="▶ Watch Video">▶ Xem Video</a>
            </div>
        </div>
    </section>

    <!-- SOCIAL PROOF STATS -->
    <div class="stats-bar" data-aos="fade-up" data-aos-delay="100">
        <div class="stat-item">
            <span class="stat-number" data-vi="10+" data-en="10+">10+</span>
            <span class="stat-label" data-vi="Plugins phát triển" data-en="Plugins developed">Plugins phát triển</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <span class="stat-number" data-vi="500+" data-en="500+">500+</span>
            <span class="stat-label" data-vi="Kiến trúc sư tin dùng" data-en="Architects trust us">Kiến trúc sư tin dùng</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <span class="stat-number" data-vi="4+" data-en="4+">4+</span>
            <span class="stat-label" data-vi="Năm phát triển" data-en="Years of development">Năm phát triển</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
            <span class="stat-number" data-vi="100%" data-en="100%">100%</span>
            <span class="stat-label" data-vi="Made in Vietnam 🇻🇳" data-en="Made in Vietnam 🇻🇳">Made in Vietnam 🇻🇳</span>
        </div>
    </div>

    
    <!-- SIMULATIONS MARQUEE -->
    <div class="marquee-container" data-aos="fade-up" data-aos-delay="200">
        <div class="marquee-track track-1">
            
            <a href="/hub" class="marquee-item">
                <div class="marquee-title">AH3 Hub<span class="detail-link-btn">Xem chi tiết</span></div>
                <div class="mini-sim-box" id="hub-sim-mq1">
                    <div class="sim-viewport">
                                <svg class="sim-svg" viewBox="0 0 200 112.5">
                                    <!-- 1. Wireframe Sketch (Base) -->
                                    <g class="wf-lines"  style="transition: opacity 0.4s;">
                                        <!-- House Block -->
                                        <rect x="35" y="45" width="85" height="55" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <rect x="45" y="60" width="65" height="40" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <polygon points="30,45 125,45 105,25 50,25" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <!-- Sphere -->
                                        <circle cx="155" cy="75" r="18" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <ellipse cx="155" cy="75" rx="18" ry="6" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <ellipse cx="155" cy="75" rx="6" ry="18" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <!-- Cylinder -->
                                        <ellipse cx="20" cy="85" rx="10" ry="3" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <ellipse cx="20" cy="98" rx="10" ry="3" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <line x1="10" y1="85" x2="10" y2="98" stroke="#4db6ac" stroke-width="0.8" />
                                        <line x1="30" y1="85" x2="30" y2="98" stroke="#4db6ac" stroke-width="0.8" />
                                    </g>

                                    <!-- 2. Flat Color Stage (Shading) -->
                                    <g class="colored-view opacity-0 pointer-events-none"  style="transition: opacity 0.5s;">
                                        <rect x="0" y="0" width="200" height="112.5" fill="#111" />
                                        <rect x="35" y="45" width="85" height="55" fill="#2d3748" />
                                        <rect x="45" y="60" width="65" height="40" fill="#319795" />
                                        <polygon points="30,45 125,45 105,25 50,25" fill="#4a5568" />
                                        <circle cx="155" cy="75" r="18" fill="#d69e2e" />
                                        <rect x="10" y="85" width="20" height="13" fill="#718096" />
                                    </g>

                                    <!-- 3. Final Neural Render (ClipPath controlled) -->
                                    <g class="rendered-view pointer-events-none" clip-path="url(#hub-clip-1)" >
                                        <!-- Sky -->
                                        <rect x="0" y="0" width="200" height="112.5" fill="url(#hub-sky-grad)" />
                                        <!-- Distant stars -->
                                        <circle cx="50" cy="25" r="0.6" fill="#fff" opacity="0.6" />
                                        <circle cx="95" cy="20" r="0.6" fill="#fff" opacity="0.8" />
                                        <!-- House Body -->
                                        <rect x="35" y="45" width="85" height="55" fill="url(#hub-wall-grad)" />
                                        <polygon points="30,45 125,45 105,25 50,25" fill="#1f2937" />
                                        <!-- Glowing Windows -->
                                        <rect x="45" y="60" width="65" height="40" fill="url(#hub-window-glow)" />
                                        <!-- Window Grids -->
                                        <line x1="77.5" y1="60" x2="77.5" y2="100" stroke="#111" stroke-width="0.8" />
                                        <line x1="45" y1="80" x2="110" y2="80" stroke="#111" stroke-width="0.8" />
                                        <!-- Light spill on floor -->
                                        <polygon points="45,100 110,100 120,112 35,112" fill="url(#hub-light-spill)" opacity="0.6" />
                                        <!-- Metallic Cylinder -->
                                        <rect x="10" y="85" width="20" height="13" fill="url(#hub-metal-grad)" />
                                        <ellipse cx="20" cy="85" rx="10" ry="3" fill="#90a4ae" />
                                        <!-- Gold Sphere -->
                                        <circle cx="155" cy="75" r="18" fill="url(#hub-gold-sphere)" />
                                    </g>
                                    <line class="scan-line hidden" x1="0" y1="0" x2="0" y2="112.5" stroke="var(--primary)" stroke-width="1.5"   />
                                    <clipPath id="hub-clip-1"><rect id="hub-clip-rect-1" x="0" y="0" width="0" height="112.5" /></clipPath>
                                </svg>
                            
                    </div>
                </div>
            </a>
            <a href="/tree" class="marquee-item">
                <div class="marquee-title">Magic Tree<span class="detail-link-btn">Xem chi tiết</span></div>
                <div class="mini-sim-box" id="tree-sim-mq1">
                    <div class="sim-viewport">
                        <svg class="sim-svg" viewBox="0 0 200 120">
                                    <g class="mini-tree-wrapper"  style="transform-origin: 100px 110px; --wind-factor: 1;">
                                        <path d="M100,110 Q105,70 100,30" stroke="#8D6E63" stroke-width="8" fill="none" stroke-linecap="round" />
                                        <circle cx="100" cy="30" r="22" fill="#66bb6a" opacity="0.85" />
                                        <circle cx="85" cy="40" r="16" fill="#4caf50" opacity="0.85" />
                                        <circle cx="115" cy="40" r="16" fill="#2e7d32" opacity="0.85" />
                                    </g>
                                </svg>
                    </div>
                </div>
            </a>
            <a href="/material" class="marquee-item">
                <div class="marquee-title">Magic Material<span class="detail-link-btn">Xem chi tiết</span></div>
                <div class="mini-sim-box" id="material-sim-mq1">
                    <div class="sim-viewport">
                        <div  class="flex justify-center items-center" style="gap:20px; height: 100%;">
                                  <div class="mini-file">diffuse</div>
                                  <div class="mini-maps-grid hidden"  style="grid-template-columns: repeat(2, 1fr); gap:4px;">
                                      <div class="mini-map-tile nrm">NRM</div>
                                      <div class="mini-map-tile rgh">RGH</div>
                                  </div>
                                  <div class="mini-scene"  style="perspective:400px;">
                                      <div class="mini-box" id="min-box-element-mq1">
                                          <div class="mini-face f-front"></div>
                                          <div class="mini-face f-top"></div>
                                          <div class="mini-face f-right"></div>
                                      </div>
                                  </div>
                              </div>
                    </div>
                </div>
            </a>
            <a href="/camera" class="marquee-item">
                <div class="marquee-title">Magic Camera<span class="detail-link-btn">Xem chi tiết</span></div>
                <div class="mini-sim-box" id="camera-sim-mq1">
                    <div class="sim-viewport">
                        <svg class="sim-svg" viewBox="0 0 200 120">
                                    <polygon points="120,95 120,65 150,45 180,65 180,95" fill="none" stroke="#666" stroke-width="1.5" />
                                    <g class="house-interior opacity-0"  style="transition: opacity 0.5s;">
                                        <line x1="120" y1="75" x2="180" y2="75" stroke="var(--primary)" stroke-width="1" />
                                        <rect x="135" y="75" width="10" height="20" fill="none" stroke="var(--primary)" stroke-width="1" />
                                    </g>
                                    <polygon class="camera-frustum opacity-0" points="50,60 110,35 110,85" fill="rgba(77,182,172,0.08)" stroke="var(--primary)" stroke-width="1" stroke-dasharray="2 2"   style="transition:opacity 0.3s;" />
                                    <g class="mini-camera" stroke="var(--primary)" stroke-width="1.5" fill="none"  style="transition: all 0.5s;">
                                        <rect x="15" y="53" width="24" height="14" rx="2" />
                                        <polygon points="39,56 45,53 45,67 39,64" />
                                        <circle cx="27" cy="60" r="3" />
                                    </g>
                                    <line class="clip-plane opacity-0" x1="150" y1="20" x2="150" y2="100" stroke="#e57373" stroke-dasharray="3 3" stroke-width="1.5"   style="transition:opacity 0.3s;" />
                                </svg>
                    </div>
                </div>
            </a>
            <a href="/hub" class="marquee-item">
                <div class="marquee-title">AH3 Hub<span class="detail-link-btn">Xem chi tiết</span></div>
                <div class="mini-sim-box" id="hub-sim-mq1">
                    <div class="sim-viewport">
                                <svg class="sim-svg" viewBox="0 0 200 112.5">
                                    <!-- 1. Wireframe Sketch (Base) -->
                                    <g class="wf-lines"  style="transition: opacity 0.4s;">
                                        <!-- House Block -->
                                        <rect x="35" y="45" width="85" height="55" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <rect x="45" y="60" width="65" height="40" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <polygon points="30,45 125,45 105,25 50,25" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <!-- Sphere -->
                                        <circle cx="155" cy="75" r="18" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <ellipse cx="155" cy="75" rx="18" ry="6" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <ellipse cx="155" cy="75" rx="6" ry="18" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <!-- Cylinder -->
                                        <ellipse cx="20" cy="85" rx="10" ry="3" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <ellipse cx="20" cy="98" rx="10" ry="3" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                        <line x1="10" y1="85" x2="10" y2="98" stroke="#4db6ac" stroke-width="0.8" />
                                        <line x1="30" y1="85" x2="30" y2="98" stroke="#4db6ac" stroke-width="0.8" />
                                    </g>

                                    <!-- 2. Flat Color Stage (Shading) -->
                                    <g class="colored-view opacity-0 pointer-events-none"  style="transition: opacity 0.5s;">
                                        <rect x="0" y="0" width="200" height="112.5" fill="#111" />
                                        <rect x="35" y="45" width="85" height="55" fill="#2d3748" />
                                        <rect x="45" y="60" width="65" height="40" fill="#319795" />
                                        <polygon points="30,45 125,45 105,25 50,25" fill="#4a5568" />
                                        <circle cx="155" cy="75" r="18" fill="#d69e2e" />
                                        <rect x="10" y="85" width="20" height="13" fill="#718096" />
                                    </g>

                                    <!-- 3. Final Neural Render (ClipPath controlled) -->
                                    <g class="rendered-view pointer-events-none" clip-path="url(#hub-clip-1)" >
                                        <!-- Sky -->
                                        <rect x="0" y="0" width="200" height="112.5" fill="url(#hub-sky-grad)" />
                                        <!-- Distant stars -->
                                        <circle cx="50" cy="25" r="0.6" fill="#fff" opacity="0.6" />
                                        <circle cx="95" cy="20" r="0.6" fill="#fff" opacity="0.8" />
                                        <!-- House Body -->
                                        <rect x="35" y="45" width="85" height="55" fill="url(#hub-wall-grad)" />
                                        <polygon points="30,45 125,45 105,25 50,25" fill="#1f2937" />
                                        <!-- Glowing Windows -->
                                        <rect x="45" y="60" width="65" height="40" fill="url(#hub-window-glow)" />
                                        <!-- Window Grids -->
                                        <line x1="77.5" y1="60" x2="77.5" y2="100" stroke="#111" stroke-width="0.8" />
                                        <line x1="45" y1="80" x2="110" y2="80" stroke="#111" stroke-width="0.8" />
                                        <!-- Light spill on floor -->
                                        <polygon points="45,100 110,100 120,112 35,112" fill="url(#hub-light-spill)" opacity="0.6" />
                                        <!-- Metallic Cylinder -->
                                        <rect x="10" y="85" width="20" height="13" fill="url(#hub-metal-grad)" />
                                        <ellipse cx="20" cy="85" rx="10" ry="3" fill="#90a4ae" />
                                        <!-- Gold Sphere -->
                                        <circle cx="155" cy="75" r="18" fill="url(#hub-gold-sphere)" />
                                    </g>
                                    <line class="scan-line hidden" x1="0" y1="0" x2="0" y2="112.5" stroke="var(--primary)" stroke-width="1.5"   />
                                    <clipPath id="hub-clip-1"><rect id="hub-clip-rect-1" x="0" y="0" width="0" height="112.5" /></clipPath>
                                </svg>
                            
                    </div>
                </div>
            </a>
            <a href="/tree" class="marquee-item">
                <div class="marquee-title">Magic Tree<span class="detail-link-btn">Xem chi tiết</span></div>
                <div class="mini-sim-box" id="tree-sim-mq1">
                    <div class="sim-viewport">
                        <svg class="sim-svg" viewBox="0 0 200 120">
                                    <g class="mini-tree-wrapper"  style="transform-origin: 100px 110px; --wind-factor: 1;">
                                        <path d="M100,110 Q105,70 100,30" stroke="#8D6E63" stroke-width="8" fill="none" stroke-linecap="round" />
                                        <circle cx="100" cy="30" r="22" fill="#66bb6a" opacity="0.85" />
                                        <circle cx="85" cy="40" r="16" fill="#4caf50" opacity="0.85" />
                                        <circle cx="115" cy="40" r="16" fill="#2e7d32" opacity="0.85" />
                                    </g>
                                </svg>
                    </div>
                </div>
            </a>
            <a href="/material" class="marquee-item">
                <div class="marquee-title">Magic Material<span class="detail-link-btn">Xem chi tiết</span></div>
                <div class="mini-sim-box" id="material-sim-mq1">
                    <div class="sim-viewport">
                        <div  class="flex justify-center items-center" style="gap:20px; height: 100%;">
                                  <div class="mini-file">diffuse</div>
                                  <div class="mini-maps-grid hidden"  style="grid-template-columns: repeat(2, 1fr); gap:4px;">
                                      <div class="mini-map-tile nrm">NRM</div>
                                      <div class="mini-map-tile rgh">RGH</div>
                                  </div>
                                  <div class="mini-scene"  style="perspective:400px;">
                                      <div class="mini-box" id="min-box-element-mq1">
                                          <div class="mini-face f-front"></div>
                                          <div class="mini-face f-top"></div>
                                          <div class="mini-face f-right"></div>
                                      </div>
                                  </div>
                              </div>
                    </div>
                </div>
            </a>
            <a href="/camera" class="marquee-item">
                <div class="marquee-title">Magic Camera<span class="detail-link-btn">Xem chi tiết</span></div>
                <div class="mini-sim-box" id="camera-sim-mq1">
                    <div class="sim-viewport">
                        <svg class="sim-svg" viewBox="0 0 200 120">
                                    <polygon points="120,95 120,65 150,45 180,65 180,95" fill="none" stroke="#666" stroke-width="1.5" />
                                    <g class="house-interior opacity-0"  style="transition: opacity 0.5s;">
                                        <line x1="120" y1="75" x2="180" y2="75" stroke="var(--primary)" stroke-width="1" />
                                        <rect x="135" y="75" width="10" height="20" fill="none" stroke="var(--primary)" stroke-width="1" />
                                    </g>
                                    <polygon class="camera-frustum opacity-0" points="50,60 110,35 110,85" fill="rgba(77,182,172,0.08)" stroke="var(--primary)" stroke-width="1" stroke-dasharray="2 2"   style="transition:opacity 0.3s;" />
                                    <g class="mini-camera" stroke="var(--primary)" stroke-width="1.5" fill="none"  style="transition: all 0.5s;">
                                        <rect x="15" y="53" width="24" height="14" rx="2" />
                                        <polygon points="39,56 45,53 45,67 39,64" />
                                        <circle cx="27" cy="60" r="3" />
                                    </g>
                                    <line class="clip-plane opacity-0" x1="150" y1="20" x2="150" y2="100" stroke="#e57373" stroke-dasharray="3 3" stroke-width="1.5"   style="transition:opacity 0.3s;" />
                                </svg>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <!-- PRODUCTS GRID -->
    <section class="products-section" id="products">
        <!-- 1. Commercial / Paid Tools (Vertical Grid) -->
        <h2 class="products-group-title" data-vi="Công cụ Thương mại (Có phí)" data-en="Commercial Plugins (Paid)">Công cụ Thương mại (Có phí)</h2>
        <div class="products-grid">
            
            <div class="product-card featured-wide" data-aos="fade-up"  style="--glow-color: rgba(77, 182, 172, 0.15); --hover-border: var(--primary);">
                <div class="premium-left flex"  style="flex-direction: column; justify-content: space-between;">
                    <div class="product-meta">
                        <div class="product-header">
                            <div class="product-icon"><img src="/ArchiH3-Icon_40.png" alt="AH3 Hub"  style="width:32px; height:32px; object-fit:contain; opacity:0.9;"></div>
                            <span class="product-badge new text-primary"  data-vi="PREMIUM" data-en="PREMIUM" style="background: rgba(77, 182, 172, 0.15); border: 1px solid rgba(77, 182, 172, 0.3);">PREMIUM</span>
                        </div>
                        <h3 class="product-title">AH3 Hub</h3>
                        <p class="product-desc" data-vi="Một siêu ứng dụng tích hợp trực tiếp vào 3ds Max. Mang AI thông minh và giải pháp tự động hóa nâng cao vào không gian làm việc." data-en="A flagship super-app for 3ds Max. Brings local AI models and advanced automation tools right to your viewport."></p>
                        
                <div class="mini-sim-box" id="hub-sim-card">
                    <div class="sim-viewport">
<svg class="sim-svg" viewBox="0 0 200 112.5">
                            <defs>
                                <linearGradient id="hub-sky-grad" x1="0%" y1="0%" x2="0%" y2="100%">
                                    <stop offset="0%" stop-color="#05020c"/>
                                    <stop offset="100%" stop-color="#140a24"/>
                                </linearGradient>
                                <linearGradient id="hub-window-glow" x1="0%" y1="0%" x2="100%" y2="100%">
                                    <stop offset="0%" stop-color="#ffb74d"/>
                                    <stop offset="100%" stop-color="#e65100"/>
                                </linearGradient>
                                <radialGradient id="hub-gold-sphere" cx="30%" cy="30%" r="70%">
                                    <stop offset="0%" stop-color="#ffe082"/>
                                    <stop offset="50%" stop-color="#ffb300"/>
                                    <stop offset="100%" stop-color="#b78103"/>
                                </radialGradient>
                                <linearGradient id="hub-wall-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                                    <stop offset="0%" stop-color="#1f2937"/>
                                    <stop offset="100%" stop-color="#111827"/>
                                </linearGradient>
                                <linearGradient id="hub-metal-grad" x1="0%" y1="0%" x2="100%" y2="0%">
                                    <stop offset="0%" stop-color="#78909c"/>
                                    <stop offset="50%" stop-color="#cfd8dc"/>
                                    <stop offset="100%" stop-color="#455a64"/>
                                </linearGradient>
                                <linearGradient id="hub-light-spill" x1="50%" y1="0%" x2="50%" y2="100%">
                                    <stop offset="0%" stop-color="#ffb74d" stop-opacity="0.25"/>
                                    <stop offset="100%" stop-color="#ffb74d" stop-opacity="0"/>
                                </linearGradient>
                            </defs>
                            
                            <!-- 1. Wireframe Sketch (Base) -->
                            <g class="wf-lines"  style="transition: opacity 0.4s;">
                                <!-- House Block -->
                                <rect x="35" y="45" width="85" height="55" fill="none" stroke="#4db6ac" stroke-width="0.8" />
                                <rect x="45" y="60" width="65" height="40" fill="none" stroke="#4db6ac" stroke-width="0.8" />
