            // Step 1: Wireframe Sketching
            btn.innerHTML = 'SKETCHING WIREFRAME...';
            btn.style.background = 'rgba(77, 182, 172, 0.15)';
            
            // Step 2: Shading Flat Colors
            setTimeout(() => {
                btn.innerHTML = 'SHADING FLAT COLORS...';
                if (coloredView) coloredView.style.opacity = '1';
                if (wfLines) wfLines.style.opacity = '0.3';
            }, 800);
            
            // Step 3: Neural AI Rendering
            setTimeout(() => {
                btn.innerHTML = 'NEURAL RENDERING...';
