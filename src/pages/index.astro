        // --- AUTOPLAY AND SCROLL DETECT LOGIC FOR VIEWPORT SIMULATIONS ---
        document.addEventListener('DOMContentLoaded', () => {
            function isElementPartiallyInViewport(el) {
                const rect = el.getBoundingClientRect();
                const windowHeight = (window.innerHeight || document.documentElement.clientHeight);
                const windowWidth = (window.innerWidth || document.documentElement.clientWidth);
                
                const vertInView = (rect.top <= windowHeight) && ((rect.top + rect.height) >= 0);
                const horInView = (rect.left <= windowWidth) && ((rect.left + rect.width) >= 0);
                
                return (vertInView && horInView);
            }

            const simBoxes = document.querySelectorAll('.mini-sim-box');
            
            // Loop checking every 15 seconds to auto-play idle simulations in the viewport
            setInterval(() => {
                simBoxes.forEach((box) => {
                    const btn = box.querySelector('.sim-action-btn');
                    if (btn && !btn.classList.contains('active') && isElementPartiallyInViewport(box)) {
                        // Stagger the triggers slightly so they don't all start at the exact same millisecond
                        const staggerDelay = Math.random() * 2000;
                        setTimeout(() => {
                            if (!btn.classList.contains('active') && isElementPartiallyInViewport(box)) {
                                btn.click();
                            }
                        }, staggerDelay);
                    }
                });
            }, 15000);

            // Trigger immediately on scroll/load if visible to catch first-impression
            let scrollTimeout;
            function triggerVisibleSims() {
                if (scrollTimeout) clearTimeout(scrollTimeout);
                scrollTimeout = setTimeout(() => {
                    simBoxes.forEach((box, index) => {
                        const btn = box.querySelector('.sim-action-btn');
                        if (btn && !btn.classList.contains('active') && !btn.dataset.firstTriggered && isElementPartiallyInViewport(box)) {
                            btn.dataset.firstTriggered = 'true';
                            setTimeout(() => {
                                if (!btn.classList.contains('active') && isElementPartiallyInViewport(box)) {
                                    btn.click();
                                }
                            }, 500 + index * 600); // Staggered launch on first view
                        }
                    });
                }, 100);
            }

            window.addEventListener('scroll', triggerVisibleSims);
            window.addEventListener('resize', triggerVisibleSims);
            
            // Initial trigger delay after page loads and transitions complete
            setTimeout(triggerVisibleSims, 1500);
        });

</script>

