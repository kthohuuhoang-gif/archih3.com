    <!-- INTERACTIVE PLAYGROUND -->
    <Showcase />

    <!-- PRODUCTS GRID -->
    <section class="products-section" id="products">
        <!-- FLAGSHIP PRODUCTS -->
        <h2 class="products-group-title" data-vi="Công cụ <span class='teal'>đột phá</span> cho 3ds Max" data-en="<span class='teal'>Breakthrough</span> tools for 3ds Max">Công cụ <span class='teal'>đột phá</span> cho 3ds Max</h2>
        <p class="products-group-subtitle" data-vi="Tự động hóa. Tối ưu hóa. Tập trung sáng tạo." data-en="Automate. Optimize. Focus on creativity.">Tự động hóa. Tối ưu hóa. Tập trung sáng tạo.</p>

        <!-- FLAGSHIP: Magic Search -->
        <div class="flagship-hero" data-aos="fade-up">
            <div class="fh-left">
                <div class="fh-titlerow">
