                                        <circle cx="95" cy="20" r="0.6" fill="#fff" opacity="0.8" />
                                        <!-- House Body -->
                                        <rect x="35" y="45" width="85" height="55" fill="url(#hub-wall-grad)" />
                                        <polygon points="30,45 125,45 105,25 50,25" fill="#1f2937" />
                                        <!-- Glowing Windows -->
